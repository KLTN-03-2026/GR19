<Window x:Class="AppCafebookApi.View.Common.ChonKhongGianWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn không gian" Height="250" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#D27D2D"/>
        <SolidColorBrush x:Key="LightCreamBrush" Color="#FFF8E1"/>
        <SolidColorBrush x:Key="WhiteTextBrush" Color="#FFFFFF"/>

        <Style TargetType="Button" x:Key="ChoiceButton">
            <Setter Property="Background" Value="{StaticResource PrimaryBrownBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteTextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource LightCreamBrush}" CornerRadius="12" BorderBrush="{StaticResource PrimaryBrownBrush}" BorderThickness="2">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.2" ShadowDepth="3"/>
            </Border.Effect>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="CHỌN KHÔNG GIAN LÀM VIỆC" FontWeight="Bold" FontSize="18" Foreground="{StaticResource PrimaryBrownBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Tài khoản của bạn có quyền Quản trị cao nhất. Bạn muốn truy cập vào giao diện nào hôm nay?" 
                           TextWrapping="Wrap" TextAlignment="Center" Foreground="#4E342E" Margin="0,10,0,20"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="👩‍💻 Quản lý (Admin)" Style="{StaticResource ChoiceButton}" Height="50" Click="BtnQuanLy_Click"/>
                    <Button Grid.Column="2" Content="☕ Nhân viên (POS)" Style="{StaticResource ChoiceButton}" Height="50" Click="BtnNhanVien_Click" Background="#4E342E"/>
                </Grid>

                <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Width="25" Height="25" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click" Margin="0,-10,-10,0">
                    <TextBlock Text="✕" Foreground="Red" FontSize="16" FontWeight="Bold"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>