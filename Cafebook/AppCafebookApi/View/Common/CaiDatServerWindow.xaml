<Window x:Class="AppCafebookApi.View.Common.CaiDatServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thiết lập kết nối Server" Height="320" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrown" Color="#6F4E37"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#D27D2D"/>
        <SolidColorBrush x:Key="LightCream" Color="#FFF8E1"/>
        <SolidColorBrush x:Key="DarkText" Color="#4E342E"/>
        <SolidColorBrush x:Key="SubtleGray" Color="#BDBDBD"/>

        <Style x:Key="MaterialButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrown}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="#4E342E"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentOrange}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource LightCream}" CornerRadius="16" Margin="15,15,15,-24" BorderBrush="{StaticResource PrimaryBrown}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="20" ShadowDepth="0"/>
            </Border.Effect>

            <Grid Margin="30,20,30,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
                    <Path Data="M16,5H14V3H12V5H10A3,3 0 0,0 7,8V14H18V8A3,3 0 0,0 15,5M20,19H4V17H20V19Z" 
                          Fill="{StaticResource PrimaryBrown}" Height="36" Width="36" Stretch="Uniform" Margin="0,0,0,10"/>
                    <TextBlock Text="KẾT NỐI HỆ THỐNG" FontWeight="Black" FontSize="20" 
                               Foreground="{StaticResource PrimaryBrown}" HorizontalAlignment="Center"/>
                    <TextBlock Text="CafeBook" FontStyle="Italic" FontSize="12" 
                               Foreground="{StaticResource AccentOrange}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Địa chỉ API Server:" Foreground="{StaticResource DarkText}" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="14"/>

                    <Grid>
                        <TextBox x:Name="txtServerUrl" 
                                 Background="Transparent" 
                                 BorderThickness="0,0,0,2" 
                                 FontSize="15" 
                                 Padding="5,8,5,8" 
                                 Foreground="{StaticResource DarkText}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="BorderBrush" Value="{StaticResource SubtleGray}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock IsHitTestVisible="False" 
                                   Text="Nhập Url máy chủ API..." 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Left" 
                                   Margin="8,0,0,0" 
                                   Foreground="#9E9E9E" 
                                   FontStyle="Italic"
                                   FontSize="15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtServerUrl}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="💡" FontSize="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Ví dụ: http://localhost:5202" FontSize="12" Foreground="Gray" FontStyle="Italic"/>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="btnSave" Grid.Row="2" Content="LƯU VÀ KẾT NỐI" 
                        Style="{StaticResource MaterialButton}" 
                        Height="45" Margin="0,20,0,0"
                        Click="BtnSave_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>