<Window x:Class="AppCafebookApi.View.Common.CaiDatServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thiết lập kết nối Server" Height="250" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="15" Background="White" BorderBrush="#6F4E37" BorderThickness="2">
        <StackPanel Margin="20">
            <TextBlock Text="THIẾT LẬP KẾT NỐI HỆ THỐNG" FontWeight="Bold" FontSize="18" 
                       Foreground="#6F4E37" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Nhập địa chỉ API Server (Lần đầu tiên):" Margin="0,0,0,5" FontSize="13"/>
            <TextBox x:Name="txtServerUrl" Padding="10" FontSize="14" 
                     Text="http://localhost:5202" BorderBrush="#BDBDBD"/>

            <TextBlock Text="Ví dụ: http://192.168.1.50:5166" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>

            <Button x:Name="btnSave" Content="LƯU VÀ KẾT NỐI" Margin="0,25,0,0" 
                    Background="#6F4E37" Foreground="White" Height="40" FontWeight="Bold"
                    Click="BtnSave_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>