<Window x:Class="AppCafebookApi.View.common.InputDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập yêu cầu" Height="400" Width="550" 
        WindowStartupLocation="CenterScreen" 
        Topmost="True"
        ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent" 
        FontFamily="Segoe UI" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="ModernWatermarkTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#3E2723"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CaretBrush" Value="#D27D2D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" 
                                    CornerRadius="12" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" Margin="{TemplateBinding Padding}"/>
                            </Border>

                            <TextBlock x:Name="watermarkText" 
                                       Text="Nhập nội dung tại đây..." 
                                       Foreground="#BCAAA4" 
                                       IsHitTestVisible="False"
                                       FontSize="16" 
                                       Margin="17,13"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="watermarkText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#D27D2D"/>
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5D4037"/>
            <Setter Property="Foreground" Value="#FFF8E1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4E342E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3E2723"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#795548"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#D7CCC8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFEBE9"/>
                    <Setter Property="Foreground" Value="#5D4037"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#FFF8E1" CornerRadius="20" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Color="Black" Opacity="0.25" ShadowDepth="8" Direction="270"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Content="✕" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Width="30" Height="30" Background="Transparent" Foreground="#8D6E63" 
                    BorderThickness="0" FontSize="16" FontWeight="Bold" Cursor="Hand" 
                    Click="BtnCancel_Click" Panel.ZIndex="1">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFCDD2"/>
                                <Setter Property="Foreground" Value="#C62828"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Left">
                <Border Background="#FFE0B2" CornerRadius="12" Width="48" Height="48" Margin="0,0,15,0">
                    <Path Data="M19,13H5V11H19V13M19,17H5V15H19V17M19,9H5V7H19V9M5,11H3V13H5V11M5,15H3V17H5V15M5,7H3V9H5V7Z" 
                          Fill="#D27D2D" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitle" Text="Nhập Lỗi Bàn" FontSize="22" FontWeight="Bold" Foreground="#3E2723"/>
                    <TextBlock x:Name="txtMessage" Text="Mô tả chi tiết lỗi bạn gặp phải" FontSize="14" Foreground="#795548" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBox x:Name="txtInput" 
                     Grid.Row="1"
                     Style="{StaticResource ModernWatermarkTextBox}" 
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto"/>

            <Grid Grid.Row="2" Margin="0,25,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Bỏ qua" Style="{StaticResource OutlineButtonStyle}" Width="110" Height="45" Margin="0,0,15,0" Click="BtnCancel_Click"/>
                <Button Grid.Column="2" Content="Xác nhận" Style="{StaticResource PrimaryButtonStyle}" Width="130" Height="45" Click="BtnOk_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>