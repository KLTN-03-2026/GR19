<Window x:Class="AppCafebookApi.View.Common.VietQRWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh Toán Chuyển Khoản" Height="700" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FFF8E1" FontFamily="Segoe UI"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QUÉT MÃ ĐỂ THANH TOÁN" FontSize="22" FontWeight="Bold" Foreground="#4E342E" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <Grid Width="300" Height="300" Margin="0,5,0,20">
                    <TextBlock x:Name="txtLoading" Text="Đang tạo mã QR..." FontSize="16" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image x:Name="imgQR" Stretch="Uniform"/>
                </Grid>

                <Grid Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ngân hàng:" FontSize="15" Foreground="Gray" Margin="0,0,15,8"/>
                    <TextBlock x:Name="lblNganHang" Grid.Row="0" Grid.Column="1" Text="---" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Số tài khoản:" FontSize="15" Foreground="Gray" Margin="0,0,15,8"/>
                    <TextBlock x:Name="lblSoTaiKhoan" Grid.Row="1" Grid.Column="1" Text="---" FontSize="18" FontWeight="Bold" Foreground="#4E342E" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Chủ tài khoản:" FontSize="15" Foreground="Gray" Margin="0,0,15,8"/>
                    <TextBlock x:Name="lblChuTaiKhoan" Grid.Row="2" Grid.Column="1" Text="---" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Số tiền:" FontSize="15" Foreground="Gray" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblSoTien" Grid.Row="3" Grid.Column="1" Text="0 đ" FontSize="24" FontWeight="Bold" Foreground="#EF5350" Margin="0,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnHuy" Grid.Column="0" Content="Hủy bỏ" Height="45" FontSize="16" Margin="0,0,8,0" Background="#E0E0E0" Click="BtnHuy_Click"/>
            <Button x:Name="btnXacNhan" Grid.Column="1" Content="Đã nhận tiền" Height="45" FontSize="16" Margin="8,0,0,0" Background="#66BB6A" Foreground="White" FontWeight="Bold" Click="BtnXacNhan_Click"/>
        </Grid>
    </Grid>
</Window>