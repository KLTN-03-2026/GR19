<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyThongBaoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Thông báo" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#F44336"/>
        </Style>

        <Style x:Key="MaterialInput" TargetType="Control">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="DatePicker" BasedOn="{StaticResource MaterialInput}"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ THÔNG BÁO" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <Button Content="🡄 Quay lại" HorizontalAlignment="Right" Style="{StaticResource ActionBtn}" Background="Gray" Click="BtnQuayLai_Click"/>
        </Grid>

        <Grid x:Name="GridDuLieu" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Loại:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbFilterLoai" Width="150" Margin="0,0,15,0"/>

                        <TextBlock Text="Từ:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpFilterTuNgay" Width="110"/>

                        <TextBlock Text="Đến:" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpFilterDenNgay" Width="110" Margin="0,0,15,0"/>

                        <TextBox x:Name="txtKeyword" Width="150" Tag="Nội dung..." Margin="0,0,10,0"/>
                        <Button x:Name="btnLoc" Content="🔍 Lọc" Style="{StaticResource ActionBtn}" Background="#2196F3" Click="BtnLoc_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgThongBao" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" BorderThickness="1" BorderBrush="#EEEEEE" Background="Transparent" SelectionChanged="DgThongBao_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Thời gian" Binding="{Binding ThoiGianTao, StringFormat='dd/MM/yyyy HH:mm'}" Width="120"/>
                            <DataGridTextColumn Header="Phân loại" Binding="{Binding LoaiThongBao}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#607D8B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Nội dung" Binding="{Binding NoiDung}" Width="*"/>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding DaXem}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Chưa xem"/>
                                        <Setter Property="Foreground" Value="#F44336"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DaXem}" Value="True">
                                                <Setter Property="Text" Value="Đã xem"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock x:Name="lblFormTitle" Text="Chi tiết Thông báo" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}"/>
                        <Button x:Name="btnLamMoiForm" Content="➕ Tạo mới" Style="{StaticResource ActionBtn}" Background="#4CAF50" HorizontalAlignment="Right" Padding="10,5" Click="BtnLamMoiForm_Click"/>
                    </Grid>

                    <StackPanel x:Name="formChiTiet" Grid.Row="1" IsEnabled="False">
                        <TextBlock Text="Phân loại Thông báo (*)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbFormLoai" Margin="0,0,0,15" DisplayMemberPath="Display" SelectedValuePath="Value"/>

                        <TextBlock Text="Nội dung chi tiết (*)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNoiDung" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"/>

                        <CheckBox x:Name="chkDaXem" Content="Đánh dấu là Đã xem" FontWeight="SemiBold" Foreground="#4E342E" Margin="0,0,0,20"/>

                        <TextBlock x:Name="lblThongTinHeThong" Text="* Đây là thông báo do Hệ thống tạo tự động. Bạn không thể đổi Phân loại." Foreground="#F44336" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,15" Visibility="Collapsed"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnLuu" Content="💾 Lưu Lại" Style="{StaticResource ActionBtn}" Background="#2196F3" Margin="0,0,10,0" Click="BtnLuu_Click"/>
                            <Button x:Name="btnXoa" Content="🗑 Xóa" Style="{StaticResource DeleteBtn}" Click="BtnXoa_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="txtThongBaoKhongCoQuyen" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="15" Padding="60,40" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" BlurRadius="25" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🛡️" FontSize="75" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="TRUY CẬP BỊ HẠN CHẾ" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            </StackPanel>
        </Border>

        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="99" Panel.ZIndex="100" Background="#80FFFFFF" Visibility="Collapsed">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </Border>
    </Grid>
</Page>