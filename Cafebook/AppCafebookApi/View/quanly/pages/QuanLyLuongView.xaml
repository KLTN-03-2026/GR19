<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyLuongView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Hệ Thống Lương" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MaterialInput" TargetType="Control">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialInput}"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ CHỐT LƯƠNG" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnNavChamCong" Content="🕒 QL Chấm Công" Style="{StaticResource ActionBtn}" Background="#607D8B" Margin="0,0,10,0" Click="BtnNavChamCong_Click"/>
                <Button x:Name="BtnNavThuongPhat" Content="⚖️ QL Thưởng Phạt Mẫu" Style="{StaticResource ActionBtn}" Background="#FF9800" Margin="0,0,10,0" Click="BtnNavThuongPhat_Click"/>
                <Button x:Name="BtnNavPhatLuong" Content="💸 QL Phát Lương" Style="{StaticResource ActionBtn}" Background="#4CAF50" Click="BtnNavPhatLuong_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="GridDuLieu" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Năm:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbNam" Width="80" SelectionChanged="CmbThoiGian_SelectionChanged"/>

                        <TextBlock Text="Tuần:" VerticalAlignment="Center" Margin="15,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbTuan" Width="80" SelectionChanged="CmbThoiGian_SelectionChanged"/>

                        <TextBlock x:Name="txtKhoangThoiGian" Text="(...)" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray" FontStyle="Italic"/>

                        <Button x:Name="btnTamTinh" Content="🔄 Tạm Tính Tự Động" Style="{StaticResource ActionBtn}" Background="#2196F3" Margin="15,0,0,0" HorizontalAlignment="Right" Click="BtnTamTinh_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgBangKe" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent" SelectionChanged="DgBangKe_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nhân viên" Binding="{Binding TenNhanVien}" Width="*"/>
                            <DataGridTextColumn Header="Lương CB" Binding="{Binding LuongCoBan, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="Giờ chuẩn" Binding="{Binding TongGioLamChuan, StringFormat='0.##'}" Width="80"/>
                            <DataGridTextColumn Header="Giờ OT" Binding="{Binding TongGioOT, StringFormat='0.##'}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2196F3"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="THỰC LÃNH" Binding="{Binding ThucLanh, StringFormat=N0}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button x:Name="btnChotLuong" Content="✅ CHỐT LƯƠNG TUẦN NÀY" Style="{StaticResource ActionBtn}" Background="#F44336" Padding="25,10" IsEnabled="False" Click="BtnChotLuong_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                <StackPanel x:Name="formChiTiet" IsEnabled="False">
                    <TextBlock Text="CHI TIẾT THƯỞNG/PHẠT" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,20"/>
                    <TextBlock x:Name="lblTenNhanVien" Text="Chọn nhân viên bên trái..." Foreground="#2196F3" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgChiTietThuongPhat" AutoGenerateColumns="False" IsReadOnly="True" Height="150" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Loại" Binding="{Binding Loai}" Width="50"/>
                            <DataGridTextColumn Header="Nguồn" Binding="{Binding Nguon}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="Foreground" Value="Gray"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Lý do" Binding="{Binding LyDo}" Width="*"/>
                            <DataGridTextColumn Header="Số tiền" Binding="{Binding SoTien, StringFormat=N0}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button x:Name="btnXoaThuongPhat" Content="🗑 Xóa khoản đang chọn (Chỉ Thủ công)" Style="{StaticResource ActionBtn}" Background="#F44336" Padding="10,6" Margin="0,0,0,20" Click="BtnXoaThuongPhat_Click"/>

                    <Border Background="#F9F9F9" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel>
                            <TextBlock Text="THÊM KHOẢN MỚI (Thủ công / Từ mẫu)" FontWeight="Bold" Margin="0,0,0,15"/>

                            <TextBlock Text="Gõ tên để tìm mẫu có sẵn:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbThuongPhatMau" DisplayMemberPath="TenMau" SelectedValuePath="IdMau" 
                                      IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="TenMau"
                                      SelectionChanged="CmbThuongPhatMau_SelectionChanged" Margin="0,0,0,15" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="Loại (*)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="cmbLoaiThuongPhat">
                                        <ComboBoxItem Content="Thưởng" IsSelected="True"/>
                                        <ComboBoxItem Content="Phạt"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Số tiền (*)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtSoTien"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Lý do (*)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtLyDoThuongPhat" TextWrapping="Wrap" AcceptsReturn="True" Height="50" Margin="0,0,0,15"/>

                            <Button x:Name="btnThemThuongPhat" Content="➕ Lưu Khoản Này" Style="{StaticResource ActionBtn}" Background="#4CAF50" Click="BtnThemThuongPhat_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>


        <Border x:Name="txtThongBaoKhongCoQuyen" 
               Grid.Row="1" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center" 
               Background="White" 
               CornerRadius="15" 
               Padding="60,40" 
               Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" BlurRadius="25" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🛡️" FontSize="75" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="TRUY CẬP BỊ HẠN CHẾ" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Bạn không có quyền quản lý Lương." FontSize="16" Foreground="#424242" HorizontalAlignment="Center"/>
                <TextBlock Text="Vui lòng sử dụng các nút chức năng phía trên thanh công cụ." FontSize="15" Foreground="Gray" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#80FFFFFF" Visibility="Collapsed">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </Border>
    </Grid>
</Page>