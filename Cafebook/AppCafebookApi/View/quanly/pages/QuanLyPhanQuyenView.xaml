<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyPhanQuyenView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Phân Quyền" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#D27D2D"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>

        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="{StaticResource PrimaryBrownBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="CẤP QUYỀN TRUY CẬP CHO TÀI KHOẢN" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <Button x:Name="btnQuayLai" Content="🡄 Quay lại" HorizontalAlignment="Right" Style="{StaticResource ActionBtn}" Background="Gray" Click="BtnQuayLai_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="1. Chọn Nhân Viên" FontSize="16" FontWeight="SemiBold" Foreground="#4E342E" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtSearchNhanVien" Grid.Column="0" Padding="5,6" FontSize="13" 
                                 BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1"
                                 TextChanged="TxtSearchNhanVien_TextChanged"/>
                        <TextBlock IsHitTestVisible="False" Text="🔍 Nhập tên..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" Foreground="Gray" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=txtSearchNhanVien}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ComboBox x:Name="cmbRoleFilter" Grid.Column="2" Padding="5" FontSize="13"
                                  BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1"
                                  SelectionChanged="CmbRoleFilter_SelectionChanged"/>
                    </Grid>

                    <DataGrid x:Name="dgNhanVien" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                              SelectionMode="Single" SelectionChanged="DgNhanVien_SelectionChanged"
                              Background="Transparent" BorderThickness="1" BorderBrush="#EEE" RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoTen}" Width="*"/>
                            <DataGridTextColumn Header="Vai Trò" Binding="{Binding TenVaiTro}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="2. Thiết lập Quyền hạn" FontSize="16" FontWeight="SemiBold" Foreground="#4E342E"/>
                    <TextBlock x:Name="txtTenNhanVienChon" Grid.Row="1" Text="Vui lòng chọn nhân viên ở danh sách bên trái..." 
                   FontSize="14" Foreground="#D27D2D" FontStyle="Italic" Margin="0,5,0,15"/>

                    <Grid Grid.Row="2" Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtSearchQuyen" Grid.Row="0" Grid.Column="0" Padding="5,6" FontSize="13" 
                     BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1"
                     TextChanged="TxtSearchQuyen_TextChanged"/>

                        <TextBlock Grid.Row="0" Grid.Column="0" IsHitTestVisible="False" Text="🔍 Tìm tên quyền..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" Foreground="Gray" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=txtSearchQuyen}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ComboBox x:Name="cmbFilterQuyen" Grid.Row="0" Grid.Column="2" Padding="5" FontSize="13"
                      BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1"
                      SelectionChanged="CmbFilterQuyen_SelectionChanged">
                            <ComboBoxItem Content="Tất cả quyền" IsSelected="True"/>
                            <ComboBoxItem Content="Quyền đã cấp"/>
                            <ComboBoxItem Content="Quyền chưa cấp"/>
                        </ComboBox>

                        <WrapPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,10,0,0">
                            <Button x:Name="btnChonTatCa" Content="Chọn tất cả hiển thị" Style="{StaticResource ActionBtn}" Background="#2196F3" Padding="10,5" Margin="0,0,10,0" Click="BtnChonTatCa_Click"/>
                            <Button x:Name="btnBoChonTatCa" Content="Bỏ chọn tất cả" Style="{StaticResource ActionBtn}" Background="#F44336" Padding="10,5" Margin="0,0,10,0" Click="BtnBoChonTatCa_Click"/>
                        </WrapPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icNhomQuyen">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,0" Visibility="{Binding Visibility}">
                                        <TextBlock Text="{Binding NhomName}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBrownBrush}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding Quyens}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding TenQuyen}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Tag="{Binding IdQuyen}"
                                                  Margin="15,4,0,4" FontSize="14" Cursor="Hand" Visibility="{Binding Visibility}"
                                                  Checked="QuyenCheckBox_Changed" Unchecked="QuyenCheckBox_Changed"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button x:Name="btnLuu" Grid.Row="4" Content="LƯU CẤU HÌNH" Style="{StaticResource ActionBtn}" 
                HorizontalAlignment="Right" Margin="0,15,0,0" Width="150" Height="35" Click="BtnLuu_Click" IsEnabled="False"/>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#80FFFFFF" Visibility="Collapsed">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>