<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLySanPhamView" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Title="Quản lý Sản phẩm" FontFamily="Segoe UI" 
      Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="SubtleGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>
        <SolidColorBrush x:Key="BackgroundHoverBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="TextGrayBrush" Color="#757575"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBrownBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Grid.Column="2" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" >
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="6" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path x:Name="Arrow" Fill="{StaticResource TextGrayBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 5 5 L 10 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />

                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="White" BorderThickness="1" BorderBrush="{StaticResource BorderGrayBrush}" CornerRadius="6" Margin="0,5,0,5">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="0,5" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{StaticResource PrimaryBrownBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBrownBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="4" Margin="5,0,5,0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrownBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ SẢN PHẨM" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnNavDanhMuc" Content="📁 Danh mục" Style="{StaticResource ActionBtn}" Background="#1976D2" Margin="0,0,10,0" Click="BtnNavDanhMuc_Click"/>
                <Button x:Name="btnNavDinhLuong" Content="⚖ Định lượng" Style="{StaticResource ActionBtn}" Background="#FF9800" Click="BtnNavDinhLuong_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="GridDuLieuSanPham" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>
            <Border Background="White" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,10" VerticalAlignment="Center">
                        <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <TextBox x:Name="txtSearchSanPham" Width="150" Style="{StaticResource InputStyle}" TextChanged="Filter_Changed" Margin="0,0,15,5"/>

                        <TextBlock Text="Danh mục:" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <ComboBox x:Name="cmbFilterDanhMuc" Width="130"  Style="{StaticResource ModernComboBoxStyle}" DisplayMemberPath="Ten" SelectedValuePath="Id" SelectionChanged="Filter_Changed" IsEditable="False" Margin="0,0,15,5"/>

                        <Button x:Name="btnLamMoiForm" Content="➕ Thêm mới" Style="{StaticResource ActionBtn}" Background="#4CAF50" Margin="0,0,15,5" Click="BtnLamMoiForm_Click"/>
                        <CheckBox x:Name="chkHienThiDaXoa" Content="Hiển thị SP Tạm ngưng" VerticalAlignment="Center" Margin="0,0,15,5" Checked="Filter_Changed" Unchecked="Filter_Changed"/>

                        <Button x:Name="btnXuatExcel" Content="📥 Xuất Excel" Style="{StaticResource ActionBtn}" Background="#2E7D32" Margin="0,0,0,5" Click="BtnXuatExcel_Click"/>
                    </WrapPanel>

                    <DataGrid x:Name="dgSanPham" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                              SelectionChanged="DgSanPham_SelectionChanged" BorderThickness="0" Background="Transparent"
                              EnableRowVirtualization="True" EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True" 
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding TenSanPham}" Width="*"/>
                            <DataGridTextColumn Header="Đơn Giá" Binding="{Binding GiaBan, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Danh Mục" Binding="{Binding TenDanhMuc}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Đang bán" Binding="{Binding TrangThaiKinhDoanh}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="8" Grid.Column="1" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="formChiTiet" IsEnabled="False">
                        <TextBlock Text="Chi tiết Sản phẩm" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1" Width="120" Height="120" Background="{StaticResource SubtleGrayBrush}">
                                <Image x:Name="AnhPreview" Stretch="Uniform"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="15,0,0,0">
                                <Button x:Name="btnChonAnh" Content="📷 Chọn ảnh" Style="{StaticResource ActionBtn}" Background="#E0E0E0" Foreground="Black" Click="BtnChonAnh_Click" Margin="0,0,0,10"/>
                                <Button x:Name="btnXoaAnh" Content="🗑 Xóa ảnh" Style="{StaticResource ActionBtn}" Background="#F44336" Click="BtnXoaAnh_Click"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Tên Sản Phẩm (*)" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtTenSanPham" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>

                        <TextBlock Text="Danh Mục (*)" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbDanhMuc" Style="{StaticResource InputStyle}" DisplayMemberPath="Ten" SelectedValuePath="Id" IsEditable="True" IsTextSearchEnabled="False" Margin="0,0,0,10" KeyUp="CmbDanhMuc_KeyUp"/>

                        <TextBlock Text="Đơn Giá (*)" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtDonGia" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="Nhóm In" FontWeight="SemiBold"/>
                                <ComboBox x:Name="cmbNhomIn" Style="{StaticResource InputStyle}" IsEditable="True">
                                    <ComboBoxItem Content="Pha chế"/>
                                    <ComboBoxItem Content="Bếp"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Trạng thái" FontWeight="SemiBold"/>
                                <ComboBox x:Name="cmbTrangThai" Style="{StaticResource InputStyle}">
                                    <ComboBoxItem Content="Đang bán"/>
                                    <ComboBoxItem Content="Tạm ngưng"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Mô tả" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtMoTa" Style="{StaticResource InputStyle}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button x:Name="btnLuu" Content="💾 Lưu" Style="{StaticResource ActionBtn}" Background="#4CAF50" Margin="0,0,10,0" Click="BtnLuu_Click"/>
                            <Button x:Name="btnXoa" Content="🗑 Xóa" Style="{StaticResource ActionBtn}" Background="#F44336" Click="BtnXoa_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="txtThongBaoKhongCoQuyen" 
                Grid.Row="1" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Background="White" 
                CornerRadius="15" 
                Padding="60,40" 
                Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="25" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🛡️" FontSize="75" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="TRUY CẬP BỊ HẠN CHẾ" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Bạn không có quyền quản lý danh sách sản phẩm." FontSize="16" Foreground="#424242" HorizontalAlignment="Center"/>
                    <TextBlock Text="Vui lòng sử dụng các nút chức năng phía trên thanh công cụ." FontSize="15" Foreground="Gray" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <Border x:Name="LoadingOverlay" Grid.ColumnSpan="2" Background="#80FFFFFF" Visibility="Collapsed">
                <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
            </Border>
        </Grid>
    </Grid>
</Page>