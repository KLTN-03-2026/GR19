<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyXuatHuyView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Xuất Hủy" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MaterialInput" TargetType="Control">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialInput}"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ XUẤT HỦY KHO" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <Button Content="🡄 Quay lại" HorizontalAlignment="Right" Style="{StaticResource ActionBtn}" Background="Gray" Click="BtnQuayLai_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="500"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Lịch sử Xuất Hủy" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtSearch" Width="150" TextChanged="TxtSearch_TextChanged"/>
                        <Button x:Name="btnLamMoiForm" Content="➕ Tạo Phiếu Mới" Style="{StaticResource ActionBtn}" Background="#4CAF50" Margin="15,0,0,0" Click="BtnLamMoiForm_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgPhieuHuy" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent" SelectionChanged="DgPhieuHuy_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding IdPhieuXuatHuy}" Width="80"/>
                            <DataGridTextColumn Header="Thời gian" Binding="{Binding ThoiGianTao, StringFormat='dd/MM/yyyy HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Lý do chung" Binding="{Binding LyDoHuy}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                <StackPanel x:Name="formChiTiet" IsEnabled="False">
                    <TextBlock x:Name="lblTitle" Text="Tạo Phiếu Hủy Mới" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,15"/>

                    <TextBlock Text="Lý do hủy chung (*)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtLyDoChung" Margin="0,0,0,15"/>

                    <Border Background="#F5F5F5" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Chọn nguyên liệu (*)" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Foreground="DimGray" Margin="0,0,5,2"/>
                            <TextBlock Text="Số lượng (dấu , nếu lẻ)" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Foreground="DimGray" Margin="0,0,5,2"/>

                            <ComboBox x:Name="cmbNguyenLieu" DisplayMemberPath="Ten" SelectedValuePath="Id" Margin="0,0,5,0" IsEditable="True" IsTextSearchEnabled="True" Grid.Row="1" Grid.Column="0"/>
                            <TextBox x:Name="txtSoLuong" Margin="0,0,5,0" Grid.Row="1" Grid.Column="1"/>

                            <Button x:Name="btnThemNL" Grid.Row="1" Grid.Column="2" Content="➕ Thêm" Style="{StaticResource ActionBtn}" Background="#D32F2F" Padding="10,5" Click="BtnThemNL_Click"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="dgChiTiet" Height="250" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="#FAFAFA" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nguyên Liệu" Binding="{Binding TenNguyenLieu}" Width="*"/>
                            <DataGridTextColumn Header="SL Hủy" Binding="{Binding SoLuong, StringFormat=N2}" Width="100"/>
                            <DataGridTemplateColumn Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑" Background="Transparent" BorderThickness="0" Foreground="Red" Cursor="Hand" Click="BtnXoaNL_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnLuu" Content="💾 LƯU PHIẾU HỦY" Style="{StaticResource ActionBtn}" Background="#D32F2F" Padding="20,10" Click="BtnLuu_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#80FFFFFF" Visibility="Collapsed">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </Border>
    </Grid>
</Page>