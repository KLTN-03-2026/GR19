<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyDinhLuongView" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Title="Định lượng" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ ĐỊNH LƯỢNG NGUYÊN LIỆU" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <Button Content="🡄 Quay lại" HorizontalAlignment="Right" Style="{StaticResource ActionBtn}" Background="Gray" Click="BtnQuayLai_Click"/>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="500"/>
            </Grid.ColumnDefinitions>
            <Border Background="White" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Tìm Sản phẩm:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtSearchSP" Width="200" Padding="5" TextChanged="TxtSearchSP_TextChanged"/>
                    </StackPanel>
                    <DataGrid x:Name="dgSanPham" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgSanPham_SelectionChanged" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding TenSanPham}" Width="*"/>
                            <DataGridTextColumn Header="Danh Mục" Binding="{Binding TenDanhMuc}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            <Border Background="White" CornerRadius="8" Grid.Column="1" Padding="20">
                <StackPanel x:Name="formChiTiet" IsEnabled="False">
                    <TextBlock x:Name="lblTitle" Text="Định lượng cho Sản phẩm" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    <DataGrid x:Name="dgDinhLuong" Height="250" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgDinhLuong_SelectionChanged" BorderThickness="0" Margin="0,0,0,20" Background="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nguyên liệu" Binding="{Binding TenNguyenLieu}" Width="*"/>
                            <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuongSuDung}" Width="80"/>
                            <DataGridTextColumn Header="Đơn vị" Binding="{Binding TenDonVi}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Nguyên liệu (*)"/>
                            <ComboBox x:Name="cmbNguyenLieu" DisplayMemberPath="Ten" SelectedValuePath="Id" Padding="8" Margin="0,5,0,0" IsEditable="True" IsTextSearchEnabled="True"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Số lượng (*)"/>
                            <TextBox x:Name="txtSoLuong" Padding="8" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Đơn vị (*)"/>
                            <ComboBox x:Name="cmbDonVi" DisplayMemberPath="Ten" SelectedValuePath="Id" Padding="8" Margin="0,5,0,0" IsEditable="True" IsTextSearchEnabled="True"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button x:Name="btnLuu" Content="💾 Lưu NL" Style="{StaticResource ActionBtn}" Background="#4CAF50" Margin="0,0,10,0" Click="BtnLuu_Click"/>
                        <Button x:Name="btnXoa" Content="🗑 Xóa NL" Style="{StaticResource ActionBtn}" Background="#F44336" Click="BtnXoa_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border x:Name="LoadingOverlay" Grid.ColumnSpan="2" Background="#80FFFFFF" Visibility="Collapsed">
                <TextBlock Text="Đang tải..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
            </Border>
        </Grid>
    </Grid>
</Page>