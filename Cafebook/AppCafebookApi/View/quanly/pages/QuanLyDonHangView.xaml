<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyDonHangView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Đơn hàng" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MaterialInput" TargetType="Control">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="DatePicker" BasedOn="{StaticResource MaterialInput}"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ ĐƠN HÀNG" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnNavPhuThu" Content="💵 Cài đặt Phụ thu" Style="{StaticResource ActionBtn}" Background="#FF9800" Margin="0,0,8,0" Click="BtnNavPhuThu_Click"/>
                <Button x:Name="btnNavShipper" Content="🛵 Quản lý Shipper" Style="{StaticResource ActionBtn}" Background="#1976D2" Margin="0,0,8,0" Click="BtnNavShipper_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="GridDuLieuDonHang" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Từ:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker x:Name="dpTuNgay" Width="110"/>

                        <TextBlock Text="Đến:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <DatePicker x:Name="dpDenNgay" Width="110"/>

                        <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <ComboBox x:Name="cmbTrangThai" Width="110">
                            <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                            <ComboBoxItem Content="Chưa thanh toán"/>
                            <ComboBoxItem Content="Đã thanh toán"/>
                            <ComboBoxItem Content="Đã hủy"/>
                        </ComboBox>

                        <TextBlock Text="Mã HĐ/SĐT:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox x:Name="txtSearch" Width="120" Tag="Nhập..."/>

                        <Button x:Name="btnSearch" Content="🔍 Lọc" Style="{StaticResource ActionBtn}" Background="#4CAF50" Margin="10,0,0,0" Click="BtnSearch_Click"/>
                        <Button x:Name="btnExportExcel" Content="📊 Excel" Style="{StaticResource ActionBtn}" Background="#00724C" Margin="10,0,0,0" Click="BtnExportExcel_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgDonHang" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent" SelectionChanged="DgDonHang_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã HĐ" Binding="{Binding IdHoaDon}" Width="60"/>
                            <DataGridTextColumn Header="Thời Gian" Binding="{Binding ThoiGianTao, StringFormat='dd/MM/yyyy HH:mm'}" Width="130"/>
                            <DataGridTextColumn Header="Bàn" Binding="{Binding TenBan}" Width="80"/>
                            <DataGridTextColumn Header="Loại Đơn" Binding="{Binding LoaiHoaDon}" Width="90"/>
                            <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TongTien, StringFormat=N0}" Width="90"/>
                            <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThai}" Width="110"/>
                            <DataGridTextColumn Header="Trạng Thái Giao" Binding="{Binding TrangThaiGiaoHang}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                <StackPanel x:Name="panelChiTiet" IsEnabled="False">
                    <TextBlock x:Name="lblTitle" Text="Chi tiết Đơn hàng" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="txtMaHD" Text="Mã HĐ: " FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtNhanVien" Text="Nhân viên: " Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtKhachHang" Text="Khách hàng: "/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="txtThoiGian" Text="Thời gian: " Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtTrangThai" Text="Trạng thái: " FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Chi tiết Sản phẩm" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DataGrid x:Name="dgChiTiet" Height="180" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="#FAFAFA" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sản phẩm" Binding="{Binding TenSanPham}" Width="*"/>
                            <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="40"/>
                            <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTien, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="txtPhuThu" Text="Phụ thu: 0" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtGiamGia" Text="Giảm giá: 0" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtGhiChu" Text="Ghi chú: " TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="TỔNG THANH TOÁN:" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="txtTongTien" Text="0 đ" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#FFF3E0" Padding="10" CornerRadius="6" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Thông tin Giao hàng" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtShipper" Text="Shipper: "/>
                            <TextBlock x:Name="txtNguoiNhan" Text="Người nhận: "/>
                            <TextBlock x:Name="txtSDTGiao" Text="SĐT: "/>
                            <TextBlock x:Name="txtDiaChiGiao" Text="Địa chỉ: " TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnHuyDon" Content="❌ Hủy Đơn" Style="{StaticResource ActionBtn}" Background="#D32F2F" Click="BtnHuyDon_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="txtThongBaoKhongCoQuyen" 
               Grid.Row="1" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center" 
               Background="White" 
               CornerRadius="15" 
               Padding="60,40" 
               Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" BlurRadius="25" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🛡️" FontSize="75" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="TRUY CẬP BỊ HẠN CHẾ" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Bạn không có quyền quản lý danh sách đơn hàng." FontSize="16" Foreground="#424242" HorizontalAlignment="Center"/>
                <TextBlock Text="Vui lòng sử dụng các nút chức năng phía trên thanh công cụ." FontSize="15" Foreground="Gray" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#80FFFFFF" Visibility="Collapsed">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </Border>
    </Grid>
</Page>