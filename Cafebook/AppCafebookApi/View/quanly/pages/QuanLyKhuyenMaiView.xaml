<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyKhuyenMaiView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Khuyến Mãi" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#F44336"/>
        </Style>

        <Style x:Key="MaterialInput" TargetType="Control">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrownBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="DatePicker" BasedOn="{StaticResource MaterialInput}"/>

        <Style x:Key="PromotionDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TrangThai}" Value="Hoạt động">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TrangThai}" Value="Tạm dừng">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#EF5350"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TrangThai}" Value="Hết hạn">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="Foreground" Value="#9E9E9E"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ KHUYẾN MÃI" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <Button x:Name="btnQuayLai" Content="🡄 Quay lại" HorizontalAlignment="Right" Style="{StaticResource ActionBtn}" Background="Gray" Click="BtnQuayLai_Click"/>
        </Grid>

        <Grid x:Name="GridDuLieu" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtTimKiem" Width="150" TextChanged="Filters_Changed" Tag="Mã, tên CT..."/>

                        <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                        <ComboBox x:Name="cmbFilterTrangThai" Width="120" SelectionChanged="Filters_Changed">
                            <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                            <ComboBoxItem Content="Hoạt động"/>
                            <ComboBoxItem Content="Tạm dừng"/>
                            <ComboBoxItem Content="Hết hạn"/>
                        </ComboBox>

                        <Button x:Name="btnLamMoiForm" Content="🔄 Làm mới" Style="{StaticResource ActionBtn}" Background="#4CAF50" Margin="15,0,0,0" Padding="10,5" Click="BtnLamMoiForm_Click"/>
                        <Button x:Name="btnXuatExcel" Content="📥 Xuất Excel" Style="{StaticResource ActionBtn}" Background="#00724C" Margin="5,0,0,0" Padding="10,5" Click="BtnXuatExcel_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgKhuyenMai" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent" SelectionChanged="DgKhuyenMai_SelectionChanged" RowStyle="{StaticResource PromotionDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã KM" Binding="{Binding MaKhuyenMai}" Width="90"/>
                            <DataGridTextColumn Header="Tên chương trình" Binding="{Binding TenChuongTrinh}" Width="*"/>
                            <DataGridTextColumn Header="Giảm" Binding="{Binding GiaTriGiam}" Width="80"/>
                            <DataGridTextColumn Header="Tối đa" Binding="{Binding GiamToiDa, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="SL Còn" Binding="{Binding SoLuongConLai}" Width="65"/>
                            <DataGridTextColumn Header="Bắt đầu" Binding="{Binding NgayBatDau, StringFormat='dd/MM/yy'}" Width="80"/>
                            <DataGridTextColumn Header="Kết thúc" Binding="{Binding NgayKetThuc, StringFormat='dd/MM/yy'}" Width="80"/>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="85"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="formChiTiet" IsEnabled="False">
                        <TextBlock x:Name="lblFormTitle" Text="Thông tin Chương trình Khuyến mãi" FontSize="20" FontWeight="Bold" Foreground="#5A3B31" Margin="0,0,0,15"/>

                        <TextBlock Text="Mã Khuyến mãi (Không dấu, VIẾT LIỀN):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMaKhuyenMai" CharacterCasing="Upper" Margin="0,0,0,15"/>

                        <TextBlock Text="Tên chương trình:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtTenChuongTrinh" Margin="0,0,0,15"/>

                        <TextBlock Text="Mô tả (Ghi chú nội bộ):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMoTa" MinHeight="40" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Loại giảm giá:" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbLoaiGiamGia">
                                    <ComboBoxItem Content="Phần Trăm" Tag="PhanTram"/>
                                    <ComboBoxItem Content="Số tiền" Tag="SoTien"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Giá trị giảm (VND hoặc %):" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtGiaTriGiam"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Giảm tối đa (Nếu là %):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtGiamToiDa" Margin="0,0,0,15"/>

                        <TextBlock Text="Mô tả ĐK (Hiển thị ở bảng):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDieuKien" Margin="0,0,0,15"/>

                        <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Margin="0,5,0,15"/>

                        <TextBlock Text="Điều kiện áp dụng (tùy chọn):" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Hóa đơn tối thiểu (VND):" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtHoaDonToiThieu"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Số lượng còn lại:" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtSoLuongConLai" ToolTip="Để trống = Không giới hạn"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Sản phẩm áp dụng:" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbSanPhamApDung" DisplayMemberPath="Ten" SelectedValuePath="Id" 
                                  IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="Ten" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Ngày Bắt đầu:" Margin="0,0,0,5"/>
                                <DatePicker x:Name="dpNgayBatDau"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ngày Kết thúc:" Margin="0,0,0,5"/>
                                <DatePicker x:Name="dpNgayKetThuc"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Thứ (vd: 2,3,4):" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtNgayTrongTuan"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Giờ Bắt đầu (HH:mm):" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtGioBatDau"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Giờ Kết thúc (HH:mm):" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtGioKetThuc"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel x:Name="pnlTrangThai" Margin="0,0,0,15" Visibility="Collapsed">
                            <TextBlock Text="Trạng thái hệ thống:" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbTrangThai" IsEnabled="False">
                                <ComboBoxItem Content="Hoạt động"/>
                                <ComboBoxItem Content="Tạm dừng"/>
                                <ComboBoxItem Content="Hết hạn"/>
                            </ComboBox>
                        </StackPanel>

                        <Button x:Name="btnTamDung" Content="⏸ Tạm Dừng / Kích Hoạt Lại" Style="{StaticResource ActionBtn}" Background="#E67E22" Margin="0,0,0,15" Click="BtnTamDung_Click" Visibility="Collapsed"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnThem" Content="➕ Thêm Mới" Style="{StaticResource ActionBtn}" Background="#4CAF50" Margin="0,0,10,0" Click="BtnThem_Click"/>
                            <Button x:Name="btnLuu" Content="💾 Lưu Cập Nhật" Style="{StaticResource ActionBtn}" Background="#2196F3" Margin="0,0,10,0" Click="BtnLuu_Click" Visibility="Collapsed"/>
                            <Button x:Name="btnXoa" Content="🗑 Xóa Bỏ" Style="{StaticResource DeleteBtn}" Click="BtnXoa_Click" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border x:Name="txtThongBaoKhongCoQuyen" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="15" Padding="60,40" Visibility="Collapsed" Panel.ZIndex="300">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" BlurRadius="25" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🛡️" FontSize="75" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="TRUY CẬP BỊ HẠN CHẾ" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Bạn không có quyền xem hoặc chỉnh sửa Khuyến Mãi." FontSize="16" Foreground="#424242" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="400">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </Border>
    </Grid>
</Page>