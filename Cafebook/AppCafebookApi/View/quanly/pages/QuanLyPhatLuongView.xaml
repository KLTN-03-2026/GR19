<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyPhatLuongView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Phát Lương" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ PHÁT LƯƠNG" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <Button Content="🡄 Quay lại" HorizontalAlignment="Right" Style="{StaticResource ActionBtn}" Background="Gray" Click="BtnQuayLai_Click"/>
        </Grid>

        <Grid x:Name="GridDuLieu" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Năm:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbNam" Width="80"/>

                        <TextBlock Text="Tháng:" VerticalAlignment="Center" Margin="15,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbThang" Width="80"/>

                        <Button x:Name="btnLoc" Content="🔍 Lọc danh sách" Style="{StaticResource ActionBtn}" Background="#2196F3" Margin="15,0,0,0" Click="BtnLoc_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgPhieuLuong" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#E0E0E0" Background="Transparent" SelectionChanged="DgPhieuLuong_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nhân viên" Binding="{Binding TenNhanVien}" Width="*"/>
                            <DataGridTextColumn Header="Kỳ Lương" Binding="{Binding KyLuong}" Width="160"/>
                            <DataGridTextColumn Header="Tổng giờ" Binding="{Binding TongGioLam, StringFormat='0.##'}" Width="70"/>
                            <DataGridTextColumn Header="Thực lãnh" Binding="{Binding ThucLanh, StringFormat=N0}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#2196F3"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Chưa phát">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Đã phát">
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- CỘT PHẢI: CHI TIẾT & IN & PHÁT -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="CHI TIẾT PHIẾU LƯƠNG" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,10"/>

                    <TextBlock x:Name="lblHuongDan" Grid.Row="1" Text="👈 Click chọn 1 nhân viên bên trái để xem chi tiết" Foreground="Gray" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <ScrollViewer x:Name="scrollChiTiet" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">

                        <Border x:Name="printArea" Width="400" Background="White" Padding="20" HorizontalAlignment="Center">
                            <StackPanel>
                                <TextBlock x:Name="lblTenQuan" Text="CAFEBOOK SYSTEM" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock x:Name="lblDiaChiQuan" Text="Địa chỉ: ..." FontSize="12" HorizontalAlignment="Center" Foreground="Gray" Margin="0,3,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock x:Name="lblSdtQuan" Text="Điện thoại: ..." FontSize="12" HorizontalAlignment="Center" Foreground="Gray" Margin="0,0,0,15"/>

                                <TextBlock Text="PHIẾU THANH TOÁN LƯƠNG" FontSize="20" FontWeight="Black" HorizontalAlignment="Center" Margin="0,10,0,5"/>
                                <TextBlock x:Name="lblKyLuong" Text="Kỳ Lương: ..." HorizontalAlignment="Center" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,20"/>

                                <Border BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,15"/>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Nhân viên:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="lblTenNhanVien" Grid.Column="1" Text="..." FontWeight="Bold" FontSize="16" Foreground="#2196F3"/>
                                </Grid>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ngày chốt:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="lblNgayChot" Grid.Column="1" Text="..."/>
                                </Grid>

                                <TextBlock Text="I. Lương Cơ Bản" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,10"/>
                                <Grid Margin="10,0,0,5">
                                    <TextBlock Text="Lương / giờ:"/>
                                    <TextBlock x:Name="lblLuongCoBan" Text="0 đ" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="10,0,0,5">
                                    <TextBlock Text="Tổng giờ làm chuẩn:"/>
                                    <TextBlock x:Name="lblTongGioLam" Text="0 h" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="10,0,0,20">
                                    <TextBlock Text="Thành tiền (A):" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="lblLuongGoc" Text="0 đ" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>

                                <Line X1="0" X2="1" Y1="0" Y2="0" Stretch="Fill" Stroke="{StaticResource BorderGrayBrush}" StrokeThickness="1" StrokeDashArray="4 2" Margin="0,0,0,20"/>

                                <TextBlock Text="II. Chi Tiết Thưởng / Phạt Bổ Sung" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,10"/>
                                <DataGrid x:Name="dgThuongPhatChiTiet" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#E0E0E0" Background="Transparent" Margin="10,0,0,10">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Loại" Binding="{Binding Loai}" Width="50"/>
                                        <DataGridTextColumn Header="Lý do" Binding="{Binding LyDo}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Số tiền" Binding="{Binding SoTien, StringFormat=N0}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Grid Margin="10,0,0,5">
                                    <TextBlock Text="Tổng Thưởng (+):" Foreground="#4CAF50"/>
                                    <TextBlock x:Name="lblTongThuong" Text="0 đ" Foreground="#4CAF50" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="10,0,0,20">
                                    <TextBlock Text="Tổng Khấu Trừ (-):" Foreground="#F44336"/>
                                    <TextBlock x:Name="lblTongKhauTru" Text="0 đ" Foreground="#F44336" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>

                                <Border BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,0,0,2" Margin="0,0,0,15"/>

                                <Border Background="#E3F2FD" Padding="15" Margin="0,0,0,15">
                                    <Grid>
                                        <TextBlock Text="THỰC LÃNH TỔNG CỘNG" FontSize="15" FontWeight="Black" VerticalAlignment="Center" Foreground="#1976D2"/>
                                        <TextBlock x:Name="lblThucLanh" Text="0 đ" FontSize="20" FontWeight="Black" HorizontalAlignment="Right" Foreground="#1976D2"/>
                                    </Grid>
                                </Border>

                                <TextBlock x:Name="lblTrangThai" Text="Trạng thái: CHƯA PHÁT" FontStyle="Italic" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <StackPanel x:Name="panelAction" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0" Visibility="Collapsed">
                        <Button x:Name="btnInPhieu" Content="🖨 In" Style="{StaticResource ActionBtn}" Background="#607D8B" Margin="0,0,10,0" Padding="20,10" Click="BtnPrint_Click"/>
                        <Button x:Name="btnXacNhanPhat" Content="✅ PHÁT LƯƠNG NÀY" Style="{StaticResource ActionBtn}" Background="#4CAF50" Padding="20,10" Click="BtnXacNhanPhat_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#80FFFFFF" Visibility="Collapsed">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </Border>
    </Grid>
</Page>