<Page x:Class="AppCafebookApi.View.quanly.pages.QuanLyDonXinNghiView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Đơn Xin Nghỉ" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#BDBDBD"/>

        <SolidColorBrush x:Key="StatusPendingBrush" Color="#FFC107"/>
        <SolidColorBrush x:Key="StatusRejectedBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="StatusApprovedBrush" Color="#4CAF50"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#6F4E37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MaterialInput" TargetType="Control">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialInput}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialInput}"/>

        <Style x:Key="StatusTextBlock" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="{Binding TrangThai}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TrangThai}" Value="Chờ duyệt">
                    <Setter Property="Foreground" Value="{StaticResource DarkBrownBrush}"/>
                    <Setter Property="Background" Value="{StaticResource StatusPendingBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TrangThai}" Value="Đã duyệt">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="{StaticResource StatusApprovedBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TrangThai}" Value="Đã từ chối">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="{StaticResource StatusRejectedBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ ĐƠN XIN NGHỈ" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
            <Button Content="🡄 Quay lại" HorizontalAlignment="Right" Style="{StaticResource ActionBtn}" Background="Gray" Click="BtnQuayLai_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtSearchNhanVien" Width="200" TextChanged="Filters_Changed" Tag="Tên nhân viên, Lý do..."/>

                        <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                        <ComboBox x:Name="cmbTrangThaiFilter" Width="150" SelectionChanged="Filters_Changed">
                            <ComboBoxItem Content="Tất cả"/>
                            <ComboBoxItem Content="Chờ duyệt" IsSelected="True"/>
                            <ComboBoxItem Content="Đã duyệt"/>
                            <ComboBoxItem Content="Đã từ chối"/>
                        </ComboBox>
                    </StackPanel>

                    <DataGrid x:Name="dgDonXinNghi" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent" SelectionChanged="DgDonXinNghi_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Trạng thái" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Margin="2">
                                            <TextBlock Style="{StaticResource StatusTextBlock}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Nhân viên" Binding="{Binding TenNhanVien}" Width="*"/>
                            <DataGridTextColumn Header="Loại đơn" Binding="{Binding LoaiDon}" Width="100"/>
                            <DataGridTextColumn Header="Từ Ngày" Binding="{Binding NgayBatDau, StringFormat='dd/MM/yyyy'}" Width="90"/>
                            <DataGridTextColumn Header="Đến Ngày" Binding="{Binding NgayKetThuc, StringFormat='dd/MM/yyyy'}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                <StackPanel x:Name="formChiTiet" IsEnabled="False">
                    <TextBlock x:Name="lblFormTitle" Text="Chi tiết Đơn Xin Nghỉ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,15"/>

                    <Border Background="#F9F9F9" Padding="15" CornerRadius="6" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Nhân viên xin nghỉ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtDetailNhanVien" IsReadOnly="True" Foreground="#424242" Background="Transparent" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="Loại đơn:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtDetailLoaiDon" IsReadOnly="True" Foreground="#424242" Background="Transparent" BorderThickness="0,0,0,1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Thời gian nghỉ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtDetailNgay" IsReadOnly="True" Foreground="#424242" Background="Transparent" BorderThickness="0,0,0,1"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Lý do nghỉ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtDetailLyDo" IsReadOnly="True" Foreground="#424242" Background="Transparent" BorderThickness="0" Height="60" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="formDuyetDon" Visibility="Collapsed">
                        <TextBlock Text="Ghi chú phê duyệt:" FontWeight="SemiBold" Foreground="#D27D2D" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtGhiChuPheDuyet" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" Style="{StaticResource MaterialInput}"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnDuyet" Content="✅ Duyệt Đơn" Style="{StaticResource ActionBtn}" Background="{StaticResource StatusApprovedBrush}" Margin="0,0,5,0" Click="BtnDuyet_Click"/>
                            <Button x:Name="btnTuChoi" Content="❌ Từ Chối" Style="{StaticResource ActionBtn}" Background="{StaticResource StatusRejectedBrush}" Margin="5,0,0,0" Click="BtnTuChoi_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="PopupConfirmShifts" Grid.RowSpan="2" Background="#99000000" Visibility="Collapsed" Panel.ZIndex="90">
            <Border Background="White" CornerRadius="8" Padding="25" Width="450" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="⚠️ XÁC NHẬN DUYỆT ĐƠN" FontSize="18" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <TextBlock Text="Khi duyệt đơn này, hệ thống sẽ TỰ ĐỘNG HỦY (xóa) các ca làm việc đã được xếp lịch của nhân viên trong khoảng thời gian xin nghỉ:" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <DataGrid x:Name="dgAffectedShifts" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="200" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ngày làm" Binding="{Binding NgayLam, StringFormat='dd/MM/yyyy'}" Width="100"/>
                            <DataGridTextColumn Header="Ca làm" Binding="{Binding TenCa}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="txtNoShifts" Text="Nhân viên không có ca làm việc nào bị trùng trong thời gian này." FontStyle="Italic" Foreground="Green" Visibility="Collapsed" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="Hủy Bỏ" Style="{StaticResource ActionBtn}" Background="Gray" Margin="0,0,15,0" Padding="20,10" Click="BtnCancelPopup_Click"/>
                        <Button Content="Xác nhận Duyệt &amp; Xóa Ca" Style="{StaticResource ActionBtn}" Background="{StaticResource StatusApprovedBrush}" Padding="20,10" Click="BtnConfirmApprove_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="100">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </Border>
    </Grid>
</Page>