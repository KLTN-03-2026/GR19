<Page x:Class="AppCafebookApi.View.nhanvien.pages.ThueSachView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AppCafebookApi.View.nhanvien.pages"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="ThueSachView" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CircleEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#3E2723"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#E64A19"/>
        <SolidColorBrush x:Key="TextGrayBrush" Color="#757575"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#43A047"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#E53935"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#D7CCC8"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="SubtleGrayBrush" Color="#F5F2EC"/>

        <FontFamily x:Key="FontAwesomeSolid">/Fonts/Font Awesome 6 Free-Solid-900.otf#Font Awesome 6 Free Solid</FontFamily>

        <Style x:Key="ModernDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="{StaticResource DarkBrownBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Padding="{TemplateBinding Padding}" VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" BorderBrush="Transparent"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="35" Cursor="Hand" Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <Path Data="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7v-5z"
                                                      Fill="{StaticResource PrimaryBrownBrush}" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextGrayBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0,0,0,3" 
                                BorderBrush="Transparent" 
                                Margin="0,0,20,0">
                            <ContentPresenter x:Name="ContentSite" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center" 
                                              ContentSource="Header" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Color="#000000" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaterialTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
                    <Setter Property="Background" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FDFDFD"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EFEFEF"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="45"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F4F0E6"/>
            <Setter Property="Foreground" Value="{StaticResource DarkBrownBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#D7CCC8"/>
        </Style>

        <local:TinhTrangColorConverter x:Key="TinhTrangColorConverter"/>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <!-- Cột Danh Sách rộng rãi -->
            <ColumnDefinition Width="*"/>
            <!-- Cột Form Panel cố định form chuẩn -->
            <ColumnDefinition Width="450"/>
        </Grid.ColumnDefinitions>

        <!-- ================= CỘT TRÁI: DANH SÁCH & TABS ================= -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header Khu vực danh sách -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="QUẢN LÝ PHIẾU THUÊ" FontSize="24" FontWeight="Heavy" Foreground="{StaticResource PrimaryBrownBrush}" VerticalAlignment="Center"/>
                    <Button Content="➕ TẠO PHIẾU MỚI" Style="{StaticResource ActionButton}" Background="{StaticResource SuccessBrush}" HorizontalAlignment="Right" Click="BtnHienThiTaoPhieu_Click" Padding="15,8"/>
                </Grid>

                <TabControl Grid.Row="1" x:Name="TabPhieu" Background="Transparent" BorderThickness="0" SelectionChanged="TabPhieu_SelectionChanged">

                    <!-- TAB 1: PHIẾU ĐANG THUÊ -->
                    <TabItem Header="📖 Phiếu Đang Thuê / Trễ" FontSize="15" FontWeight="SemiBold">
                        <Grid Margin="0,15,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Khối Bộ Lọc -->
                            <Border Grid.Row="0" Background="{StaticResource SubtleGrayBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                <WrapPanel VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,20,10">
                                        <TextBlock Text="Tìm SĐT/Tên/Mã" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                        <TextBox x:Name="txtSearchPhieuThue" Style="{StaticResource MaterialTextBox}" Width="160" Height="35" TextChanged="TxtSearchPhieuThue_TextChanged"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,20,10">
                                        <TextBlock Text="Ngày thuê (Từ - Đến)" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal">
                                            <DatePicker x:Name="dpLocNgayThueTu" Width="110" Style="{StaticResource ModernDatePickerStyle}" SelectedDateChanged="DpLocNgayThue_SelectedDateChanged"/>
                                            <TextBlock Text="-" VerticalAlignment="Center" Margin="5,0"/>
                                            <DatePicker x:Name="dpLocNgayThueDen" Width="110" Style="{StaticResource ModernDatePickerStyle}" SelectedDateChanged="DpLocNgayThue_SelectedDateChanged"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,15,10">
                                        <TextBlock Text="Trạng thái" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="cmbTrangThaiFilter" Width="120" Height="35" Padding="8,6" SelectionChanged="CmbTrangThaiFilter_SelectionChanged">
                                            <ComboBoxItem Content="Tất Cả"/>
                                            <ComboBoxItem Content="Đang Thuê" IsSelected="True"/>
                                            <ComboBoxItem Content="Trễ Hạn"/>
                                            <ComboBoxItem Content="Đã Trả"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <Button Content="Xóa lọc" Style="{StaticResource ActionButton}" Background="{StaticResource TextGrayBrush}" Padding="15,0" Height="35" Margin="0,17,0,10" Click="BtnXoaLocThue_Click"/>
                                </WrapPanel>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="dgPhieuThue" IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="DgPhieuThue_SelectionChanged" LoadingRow="DgPhieuThue_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã" Binding="{Binding IdPhieuThueSach}" Width="60" FontWeight="Bold"/>
                                    <DataGridTextColumn Header="Khách Hàng" Binding="{Binding HoTenKH}" Width="*"/>
                                    <DataGridTextColumn Header="SĐT" Binding="{Binding SoDienThoaiKH}" Width="105"/>
                                    <DataGridTextColumn Header="Hẹn Trả" Binding="{Binding NgayHenTra, StringFormat='dd/MM/yyyy'}" Width="95"/>
                                    <DataGridTemplateColumn Header="Tình Trạng" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TinhTrang}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding TinhTrang, Converter={StaticResource TinhTrangColorConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Thao tác" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button ToolTip="Liên Hệ" Style="{StaticResource ActionButton}" Padding="8,5" Margin="3" Background="#42A5F5" Click="BtnLienHe_Click">
                                                        <TextBlock FontFamily="{StaticResource FontAwesomeSolid}" Text="&#xf095;"/>
                                                    </Button>
                                                    <Button ToolTip="Gia Hạn" Style="{StaticResource ActionButton}" Padding="8,5" Margin="3" Background="{StaticResource AccentOrangeBrush}" Click="BtnGiaHan_Click">
                                                        <TextBlock FontFamily="{StaticResource FontAwesomeSolid}" Text="&#xf017;"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- TAB 2: LỊCH SỬ TRẢ -->
                    <TabItem Header="🕰️ Lịch Sử Trả Sách" FontSize="15" FontWeight="SemiBold">
                        <Grid Margin="0,15,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource SubtleGrayBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                <WrapPanel VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,20,10">
                                        <TextBlock Text="Tìm Mã Phiếu" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                        <TextBox x:Name="txtSearchPhieuTra" Style="{StaticResource MaterialTextBox}" Width="160" Height="35" TextChanged="TxtSearchPhieuTra_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,10">
                                        <TextBlock Text="Ngày trả (Từ - Đến)" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal">
                                            <DatePicker x:Name="dpLocNgayTraTu" Width="110" Style="{StaticResource ModernDatePickerStyle}" SelectedDateChanged="DpLocNgayTra_SelectedDateChanged"/>
                                            <TextBlock Text="-" VerticalAlignment="Center" Margin="5,0"/>
                                            <DatePicker x:Name="dpLocNgayTraDen" Width="110" Style="{StaticResource ModernDatePickerStyle}" SelectedDateChanged="DpLocNgayTra_SelectedDateChanged"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Content="Xóa lọc" Style="{StaticResource ActionButton}" Background="{StaticResource TextGrayBrush}" Padding="15,0" Height="35" Margin="0,17,0,10" Click="BtnXoaLocTra_Click"/>
                                </WrapPanel>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="dgPhieuTra" IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="DgPhieuTra_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã Trả" Binding="{Binding IdPhieuTra}" Width="70" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
                                    <DataGridTextColumn Header="Mã Thuê" Binding="{Binding IdPhieuThueSach}" Width="75" Foreground="Gray"/>
                                    <DataGridTextColumn Header="Ngày Trả" Binding="{Binding NgayTra, StringFormat='dd/MM/yyyy HH:mm'}" Width="135"/>
                                    <DataGridTextColumn Header="Nhân Viên Thu" Binding="{Binding TenNhanVien}" Width="*"/>
                                    <DataGridTextColumn Header="Hoàn Cọc" Binding="{Binding TongHoanTra, StringFormat=N0}" Width="110" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- ================= CỘT PHẢI: FORM ĐA NĂNG ================= -->
        <Grid Grid.Column="1">

            <!-- 1. PANEL TẠO PHIẾU MỚI (Mặc định) -->
            <Border x:Name="panelTaoPhieu" Background="White" CornerRadius="12" Padding="25" Visibility="Visible">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <TextBlock Text="Thông Tin Lập Phiếu" FontSize="20" FontWeight="Heavy" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,15"/>

                        <TextBlock Text="Tên Khách Hàng *" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,10,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtHoTenKH" Style="{StaticResource MaterialTextBox}" Height="35" TextChanged="TxtKhachInfo_TextChanged"/>

                        <TextBlock Text="Số Điện Thoại * (Gõ để tìm KH)" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,15,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtSdtKH" Style="{StaticResource MaterialTextBox}" Height="35" TextChanged="TxtKhachInfo_TextChanged"/>

                        <TextBlock Text="Email (Tùy chọn)" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,15,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtEmailKH" Style="{StaticResource MaterialTextBox}" Height="35"/>

                        <ListBox x:Name="lbKhachHangResults" MaxHeight="120" SelectionChanged="LbKhachHangResults_SelectionChanged" Visibility="Collapsed" Margin="0,5,0,0" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1">
                            <ListBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding HoTen}" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}"/>
                                        <TextBlock Text="{Binding SoDienThoai}" Foreground="{StaticResource TextGrayBrush}" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Separator Margin="0,20"/>

                        <TextBlock Text="Tìm Sách Mượn * (Gõ Tên hoặc ID)" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtSearchSach" Style="{StaticResource MaterialTextBox}" Height="35" TextChanged="TxtSearchSach_TextChanged"/>
                        <ListBox x:Name="lbSachResults" MaxHeight="120" SelectionChanged="LbSachResults_SelectionChanged" Visibility="Collapsed" Margin="0,5,0,0" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1">
                            <ListBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="2">
                                        <Run Text="[ID: " Foreground="Gray"/><Run Text="{Binding IdSach}" FontWeight="Bold"/><Run Text="] - " Foreground="Gray"/>
                                        <Run Text="{Binding TenSach}" FontWeight="SemiBold"/>
                                        <Run Text=" (Còn: " Foreground="Gray"/><Run Text="{Binding SoLuongHienCo}" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold"/><Run Text=")" Foreground="Gray"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Sách Chọn Thuê:" FontSize="13" Foreground="{StaticResource DarkBrownBrush}" Margin="0,15,0,5" FontWeight="Bold"/>
                        <DataGrid x:Name="dgSachChon" AutoGenerateColumns="False" MaxHeight="180" IsReadOnly="True" CanUserAddRows="False" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên Sách" Binding="{Binding TenSach}" Width="*"/>
                                <DataGridTextColumn Header="Cọc" Binding="{Binding GiaBia, StringFormat=N0}" Width="75"/>
                                <DataGridTextColumn Header="Mới(%)" Binding="{Binding DoMoiKhiThue}" Width="65" Foreground="{StaticResource AccentOrangeBrush}" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChuKhiThue}" Width="85"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,15">
                            <Button Content="Sửa độ mới" Background="{StaticResource AccentOrangeBrush}" Style="{StaticResource ActionButton}" Padding="15,6" FontSize="12" Margin="0,0,8,0" Click="BtnSuaSachChon_Click"/>
                            <Button Content="Xóa sách" Background="{StaticResource ErrorBrush}" Style="{StaticResource ActionButton}" Padding="15,6" FontSize="12" Click="BtnXoaSachChon_Click"/>
                        </StackPanel>

                        <TextBlock Text="Ngày Hẹn Trả *" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpNgayHenTra" Height="35" FontSize="14" Padding="5"/>

                        <Border Background="{StaticResource SubtleGrayBrush}" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Tổng Tiền Cọc Yêu Cầu:" FontWeight="SemiBold" Foreground="{StaticResource TextGrayBrush}"/>
                                <TextBlock x:Name="lblTongCoc" Text="0 đ" FontSize="22" FontWeight="Heavy" Foreground="{StaticResource PrimaryBrownBrush}" Margin="0,2,0,10"/>
                                <TextBlock Text="Phí thuê (tạm tính):" FontWeight="SemiBold" Foreground="{StaticResource TextGrayBrush}"/>
                                <TextBlock x:Name="lblPhiThue" Text="0 đ" FontSize="16" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="btnTaoPhieuThue" Background="{StaticResource SuccessBrush}" Style="{StaticResource ActionButton}" Padding="0,12" Margin="0,20,0,0" Click="BtnTaoPhieuThue_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource FontAwesomeSolid}" Text="&#xf067;" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="XÁC NHẬN TẠO PHIẾU" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 2. PANEL CHI TIẾT & TRẢ SÁCH (Ẩn mặc định) -->
            <Border x:Name="panelChiTietPhieu" Background="White" CornerRadius="12" Padding="25" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <TextBlock Text="Chi Tiết &amp; Trả Sách" FontSize="20" FontWeight="Heavy" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,10"/>
                        <TextBlock x:Name="lblTenKH_ChiTiet" Text="Nguyễn Văn A" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}"/>
                        <TextBlock x:Name="lblSdtKH_ChiTiet" Text="0909123456" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,20"/>

                        <StackPanel x:Name="panelTraSachInput">
                            <TextBlock Text="Chọn và Đánh giá sách trả:" FontSize="13" Foreground="{StaticResource DarkBrownBrush}" Margin="0,0,0,5" FontWeight="Bold"/>
                            <DataGrid x:Name="dgSachTra" AutoGenerateColumns="False" MaxHeight="280" SelectionMode="Single" CanUserAddRows="False" IsReadOnly="False" Margin="0,5,0,15">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridTextColumn Header="Tên Sách" Binding="{Binding TenSach}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="% Thuê" Binding="{Binding DoMoiKhiThue, StringFormat={}{0}%}" Width="65" IsReadOnly="True" Foreground="Gray"/>
                                    <DataGridTextColumn Header="% Trả" Binding="{Binding DoMoiKhiTra, StringFormat={}{0}%}" Width="60" IsReadOnly="True" Foreground="{StaticResource AccentOrangeBrush}" FontWeight="Bold"/>

                                    <DataGridTemplateColumn Header="Đánh Giá" Width="85">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Cập nhật" Style="{StaticResource ActionButton}" Background="{StaticResource AccentOrangeBrush}" Padding="8,4" FontSize="12" Click="BtnMoPopupDanhGiaTra_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Background="{StaticResource SubtleGrayBrush}" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="Tổng Tiền Phạt Trễ &amp; Hư Hỏng:" FontWeight="SemiBold" Foreground="{StaticResource TextGrayBrush}"/>
                                    <TextBlock x:Name="lblTongPhat" Text="0 đ" FontSize="16" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" Margin="0,2,0,10"/>
                                    <TextBlock Text="Tổng Phí Thuê Sách:" FontWeight="SemiBold" Foreground="{StaticResource TextGrayBrush}"/>
                                    <TextBlock x:Name="lblTongPhiThue_Tra" Text="0 đ" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}" Margin="0,2,0,10"/>
                                    <TextBlock Text="SỐ TIỀN CỌC HOÀN TRẢ:" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}"/>
                                    <TextBlock x:Name="lblTongCoc_Tra" Text="0 đ" FontSize="24" FontWeight="Heavy" Foreground="{StaticResource SuccessBrush}"/>
                                </StackPanel>
                            </Border>

                            <Button x:Name="btnXacNhanTra" Background="{StaticResource SuccessBrush}" Style="{StaticResource ActionButton}" Padding="0,12" Margin="0,20,0,0" Click="BtnXacNhanTra_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource FontAwesomeSolid}" Text="&#xf00c;" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="XÁC NHẬN TRẢ SÁCH" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Separator Margin="0,25"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnInPhieu" Grid.Column="0" Content="🖨️ In Phiếu Thuê" Style="{StaticResource ActionButton}" Background="#42A5F5" Padding="0,10" Margin="0,0,5,0" Click="BtnInPhieu_Click"/>
                            <Button x:Name="btnInPhieuTra" Grid.Column="1" Content="🖨️ In Phiếu Trả" Style="{StaticResource ActionButton}" Background="{StaticResource AccentOrangeBrush}" Padding="0,10" Margin="5,0,0,0" Visibility="Collapsed" Click="BtnInPhieuTra_Click"/>
                        </Grid>
                        <Button x:Name="btnGuiNhacHen" Content="📧 Gửi Email Nhắc Hẹn" Style="{StaticResource ActionButton}" Background="{StaticResource TextGrayBrush}" Padding="0,10" Margin="0,10,0,0" Visibility="Collapsed" Click="BtnGuiNhacHen_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ================= CÁC POPUP TƯƠNG TÁC MÀN HÌNH ================= -->
        <Border x:Name="PopupNhapSachThue" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed" Panel.ZIndex="15">
            <Border Background="White" CornerRadius="12" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="ĐÁNH GIÁ SÁCH TRƯỚC KHI THUÊ" FontWeight="Heavy" FontSize="18" Foreground="{StaticResource PrimaryBrownBrush}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock x:Name="lblTenSachThuePopup" Text="Tên sách" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,15" HorizontalAlignment="Center" Foreground="{StaticResource AccentOrangeBrush}"/>

                    <TextBlock Text="Độ mới (%)" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtDoMoiThuePopup" Style="{StaticResource MaterialTextBox}" Text="100" Height="35"/>

                    <TextBlock Text="Ghi chú tình trạng sách" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,15,0,5" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtGhiChuThuePopup" Style="{StaticResource MaterialTextBox}" Height="70" AcceptsReturn="True" TextWrapping="Wrap"/>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Hủy" Grid.Column="0" Style="{StaticResource ActionButton}" Background="{StaticResource TextGrayBrush}" Padding="0,10" Margin="0,0,5,0" Click="BtnHuyNhapSachThue_Click"/>
                        <Button Content="Xác Nhận" Grid.Column="1" Style="{StaticResource ActionButton}" Background="{StaticResource SuccessBrush}" Padding="0,10" Margin="5,0,0,0" Click="BtnXacNhanNhapSachThue_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="PopupDanhGiaTra" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed" Panel.ZIndex="15">
            <Border Background="White" CornerRadius="12" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="ĐÁNH GIÁ TÌNH TRẠNG TRẢ" FontWeight="Heavy" FontSize="18" Foreground="{StaticResource PrimaryBrownBrush}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock x:Name="lblTenSachTraPopup" Text="Tên sách" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" HorizontalAlignment="Center" Foreground="{StaticResource AccentOrangeBrush}"/>
                    <TextBlock x:Name="lblDoMoiThuePopup" Text="Độ mới lúc thuê: 100%" FontSize="13" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,15"/>

                    <TextBlock Text="Độ mới lúc trả (%)" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtDoMoiTraPopup" Style="{StaticResource MaterialTextBox}" Height="35"/>

                    <TextBlock Text="Ghi chú (Lý do hư hỏng nếu có)" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,15,0,5" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtGhiChuTraPopup" Style="{StaticResource MaterialTextBox}" Height="70" AcceptsReturn="True" TextWrapping="Wrap"/>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Hủy" Grid.Column="0" Style="{StaticResource ActionButton}" Background="{StaticResource TextGrayBrush}" Padding="0,10" Margin="0,0,5,0" Click="BtnHuyDanhGiaTra_Click"/>
                        <Button Content="Xác Nhận" Grid.Column="1" Style="{StaticResource ActionButton}" Background="{StaticResource SuccessBrush}" Padding="0,10" Margin="5,0,0,0" Click="BtnXacNhanDanhGiaTra_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="GiaHanOverlay" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed" Panel.ZIndex="10">
            <Border Background="White" CornerRadius="12" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <StackPanel>
                    <TextBlock Text="GIA HẠN PHIẾU THUÊ" FontWeight="Heavy" FontSize="20" Foreground="{StaticResource PrimaryBrownBrush}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock x:Name="lblGiaHanInfo" Text="Phiếu: PT0001 - Khách: Nguyễn Văn A" Margin="0,0,0,20" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>

                    <TextBlock Text="Chọn ngày hẹn trả mới (Bắt buộc):" FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpGiaHan" Margin="0,0,0,30" Height="35" FontSize="14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Đóng" Grid.Column="0" Style="{StaticResource ActionButton}" Background="{StaticResource TextGrayBrush}" Padding="0,10" Margin="0,0,5,0" Click="BtnHuyGiaHan_Click"/>
                        <Button Content="Xác Nhận" Grid.Column="1" Style="{StaticResource ActionButton}" Background="{StaticResource SuccessBrush}" Padding="0,10" Margin="5,0,0,0" Click="BtnXacNhanGiaHan_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="LoadingOverlay" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="20">
            <TextBlock Text="Đang tải..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
        </Border>
    </Grid>
</Page>