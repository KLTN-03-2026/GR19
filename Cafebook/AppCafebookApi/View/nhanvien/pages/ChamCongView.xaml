<Page x:Class="AppCafebookApi.View.nhanvien.pages.ChamCongView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Chấm Công" FontFamily="Segoe UI" Background="#FFF8E1" Loaded="Page_Loaded">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrownBrush" Color="#6F4E37"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#D27D2D"/>
        <SolidColorBrush x:Key="LightCreamBrush" Color="#FFF8E1"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#757575"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#212121"/>
        <SolidColorBrush x:Key="BorderGrayBrush" Color="#E0E0E0"/>

        <SolidColorBrush x:Key="SuccessBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#C62828"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F57F17"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#1565C0"/>

        <DropShadowEffect x:Key="SoftShadow" ShadowDepth="2" BlurRadius="15" Opacity="0.1" Color="#4E342E" Direction="270"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="150" CenterY="27"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenterAlign" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="txtHeaderTitle" Text="Chấm Công Nhân Viên" FontSize="26" FontWeight="Black" Foreground="{StaticResource PrimaryBrownBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="btnXemLichSu" Content="📋 Xem Lịch Sử" Style="{StaticResource ActionBtn}" Background="{StaticResource AccentOrangeBrush}" Margin="0,0,10,0" Click="BtnXemLichSu_Click"/>
                <Button Content="🡄 Quay lại" Style="{StaticResource ActionBtn}" Background="#9E9E9E" Click="BtnQuayLai_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">

            <Grid x:Name="viewDiemDanh" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="40" Margin="0,0,20,0" Effect="{StaticResource SoftShadow}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="txtDate" Text="--/--/----" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock x:Name="txtClock" Text="00:00:00" FontSize="75" FontFamily="Consolas" FontWeight="Black" Foreground="{StaticResource DarkBrownBrush}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                        <Border x:Name="brdTrangThaiCa" Background="#F5F5F5" CornerRadius="20" Padding="25,10" HorizontalAlignment="Center" Margin="0,0,0,30">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Trạng thái: " FontSize="16" Foreground="{StaticResource TextLightBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="txtTrangThaiCa" Text="Đang tải..." FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Grid Height="55" Width="300">
                            <Button x:Name="btnVaoCa" Content="VÀO CA BẮT ĐẦU LÀM" Background="{StaticResource SuccessBrush}" Style="{StaticResource ModernActionBtn}" Visibility="Collapsed" Click="BtnVaoCa_Click"/>
                            <Button x:Name="btnRaCa" Content="TRẢ CA (RA VỀ)" Background="{StaticResource DangerBrush}" Style="{StaticResource ModernActionBtn}" Visibility="Collapsed" Click="BtnRaCa_Click"/>
                            <Border x:Name="brdLoadingBtn" Background="{StaticResource BorderGrayBrush}" CornerRadius="12" Visibility="Visible">
                                <TextBlock Text="Đang tải dữ liệu..." Foreground="{StaticResource TextLightBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="30" Effect="{StaticResource SoftShadow}">
                    <StackPanel>
                        <TextBlock Text="Thông tin Ca Làm Việc" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}" Margin="0,0,0,20"/>

                        <Border Background="{StaticResource LightCreamBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,25" BorderBrush="{StaticResource AccentOrangeBrush}" BorderThickness="1,0,0,0">
                            <StackPanel>
                                <TextBlock x:Name="txtNhanVien" Text="Nhân viên: ---" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>
                                <TextBlock x:Name="txtTenCa" Text="Ca hiện tại: ---" FontSize="15" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtThoiGianCa" Text="Quy định: ---" FontSize="14" Foreground="{StaticResource PrimaryBrownBrush}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Chi tiết phiên làm việc" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrownBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="Hệ thống hỗ trợ ra/vào ca nhiều lần. Thời gian làm được cộng dồn." TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextLightBrush}" FontStyle="Italic" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Vào gần nhất:" FontSize="15" Foreground="{StaticResource TextLightBrush}"/>
                            <TextBlock x:Name="txtGioVao" Grid.Column="1" Text="--:--" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ra gần nhất:" FontSize="15" Foreground="{StaticResource TextLightBrush}"/>
                            <TextBlock x:Name="txtGioRa" Grid.Column="1" Text="--:--" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Separator Background="{StaticResource BorderGrayBrush}" Margin="0,0,0,20"/>

                        <TextBlock Text="Tổng giờ làm hôm nay" FontSize="15" Foreground="{StaticResource TextLightBrush}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtThoiGianLam" Text="00:00:00" FontSize="36" FontFamily="Consolas" FontWeight="Black" Foreground="{StaticResource AccentOrangeBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="viewLichSu" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource SoftShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Xem tháng:" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,15,0"/>
                            <DatePicker x:Name="dpChonThang" Width="140" FontSize="14" SelectedDateChanged="dpChonThang_SelectedDateChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Background="#FFF3E0" CornerRadius="8" Padding="15,8" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Tổng thời gian làm:" Foreground="{StaticResource AccentOrangeBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="txtTongGio" Text="0 giờ" FontSize="16" FontWeight="Black" Foreground="{StaticResource AccentOrangeBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FFEBEE" CornerRadius="8" Padding="15,8" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Đi trễ:" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="txtDiTre" Text="0 lần" FontSize="16" FontWeight="Black" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FBE9E7" CornerRadius="8" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Về sớm:" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="txtVeSom" Text="0 lần" FontSize="16" FontWeight="Black" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="10" Effect="{StaticResource SoftShadow}">
                    <DataGrid x:Name="dgLichSu" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                              Background="Transparent" BorderThickness="0" RowHeight="45" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding Ngay}" Width="120" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Ca làm" Binding="{Binding CaLamViec}" Width="150"/>
                            <DataGridTextColumn Header="Vào đầu" Binding="{Binding GioVaoNhanhNhat}" Width="90" ElementStyle="{StaticResource CenterAlign}"/>
                            <DataGridTextColumn Header="Ra cuối" Binding="{Binding GioRaMuonNhat}" Width="90" ElementStyle="{StaticResource CenterAlign}"/>
                            <DataGridTextColumn Header="Số phiên" Binding="{Binding SoLanRaVao}" Width="75" ElementStyle="{StaticResource CenterAlign}"/>
                            <DataGridTextColumn Header="Đi trễ" Binding="{Binding DiTre}" Width="100" Foreground="{StaticResource DangerBrush}" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Về sớm" Binding="{Binding VeSom}" Width="100" Foreground="{StaticResource WarningBrush}" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Tổng giờ công" Binding="{Binding TongGioLam, StringFormat={}{0:N2} giờ}" Width="*" FontWeight="Black" Foreground="{StaticResource AccentOrangeBrush}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Page>