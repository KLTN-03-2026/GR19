<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Custom Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="4dp"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/cafe_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Chi tiết thuê sách"
            android:textColor="@color/cafe_brown"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Rental Info Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvIdPhieu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã phiếu: #123"
                    android:textColor="@color/cafe_brown"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_badge_brown"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Đang thuê"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Rental Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0EBE1"
                app:strokeWidth="1dp">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:padding="16dp">

                    <TextView android:text="Ngày thuê:" android:textColor="@color/cf_text_hint" android:textSize="14sp" />
                    <TextView android:id="@+id/tvNgayThue" android:text="10/05/2026" android:textColor="@color/cafe_brown" android:gravity="end" />

                    <TextView android:text="Hạn trả:" android:textColor="@color/cf_text_hint" android:textSize="14sp" android:layout_marginTop="8dp"/>
                    <TextView android:id="@+id/tvHanTra" android:text="17/05/2026" android:textColor="@color/cafe_brown" android:gravity="end" android:layout_marginTop="8dp"/>

                    <TextView android:id="@+id/lblNgayTra" android:text="Ngày trả thực tế:" android:textColor="@color/cf_text_hint" android:textSize="14sp" android:layout_marginTop="8dp" android:visibility="gone"/>
                    <TextView android:id="@+id/tvNgayTra" android:text="-" android:textColor="@color/cafe_brown" android:gravity="end" android:layout_marginTop="8dp" android:visibility="gone"/>
                </GridLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Book List Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="Danh sách sách thuê"
                android:textColor="@color/cafe_brown"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Payment Summary Card -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="Chi tiết thanh toán"
                android:textColor="@color/cafe_brown"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0EBE1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2">

                        <TextView android:text="Tổng tiền cọc:" android:textColor="@color/cf_text_hint" />
                        <TextView android:id="@+id/tvTienCoc" android:text="150,000đ" android:textColor="@color/cafe_brown" android:gravity="end" />

                        <TextView android:text="Phí thuê sách:" android:textColor="@color/cf_text_hint" android:layout_marginTop="8dp"/>
                        <TextView android:id="@+id/tvPhiThue" android:text="45,000đ" android:textColor="@color/cafe_brown" android:gravity="end" android:layout_marginTop="8dp"/>

                        <TextView android:text="Tổng tiền phạt:" android:textColor="@color/cf_text_hint" android:layout_marginTop="8dp"/>
                        <TextView android:id="@+id/tvTienPhat" android:text="0đ" android:textColor="@color/cafe_orange" android:gravity="end" android:layout_marginTop="8dp"/>
                    </GridLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="#F0EBE1" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/lblCocHoan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tiền cọc hoàn trả:"
                            android:textColor="@color/cafe_brown"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCocHoan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="105,000đ"
                            android:textColor="@color/cafe_orange"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNoteEstimate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/lblCocHoan"
                            android:layout_marginTop="4dp"
                            android:text="(*Số tiền tạm tính đến hiện tại)"
                            android:textColor="@color/cf_text_hint"
                            android:textSize="11sp"
                            android:visibility="gone"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
