@page "/thu-vien-sach/tim-kiem"
@model WebCafebookApi.Pages.TimKiemSachViewModel
@using CafebookModel.Utils
@{
    ViewData["Title"] = Model.PageTitle;
}

@section Styles {
    <link rel="stylesheet" href="~/css/TimKiemSachView.css" asp-append-version="true" />
}

<div class="container mt-4 mb-5">
    
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/TrangChuView" class="text-decoration-none" style="color: var(--cf-brown);"><span class="material-symbols-outlined align-text-bottom fs-6">home</span></a></li>
            <li class="breadcrumb-item"><a asp-page="/ThuVienSachView" class="text-decoration-none" style="color: var(--cf-brown);">Thư Viện Sách</a></li>
            <li class="breadcrumb-item active" aria-current="page">Tìm kiếm kết quả</li>
        </ol>
    </nav>

    <div class="search-header-section shadow-sm mb-5">
        <h1 class="display-6 fw-bold position-relative z-1" style="color: var(--cf-dark-brown);">@Model.PageTitle</h1>
        
        @if (!string.IsNullOrEmpty(Model.PageDescription))
        {
            <div id="page-description-wrapper" class="description-truncated mt-3 position-relative z-1">
                <p class="fs-6 text-muted mb-0" style="line-height: 1.6;">@Model.PageDescription</p>
            </div>
            <a href="javascript:void(0);" id="toggle-page-description" class="text-decoration-none fw-bold mt-2 d-inline-block position-relative z-1" style="color: var(--cf-orange); display:none;">
                Đọc tiếp <span class="material-symbols-outlined align-middle" style="font-size: 1.2rem;">expand_more</span>
            </a>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger shadow-sm rounded-3 d-flex align-items-center">
            <span class="material-symbols-outlined me-2">error</span>
            @Model.ErrorMessage
        </div>
    }

    @if (Model.SachList != null && Model.SachList.Any())
    {
        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-4">
            @foreach (var item in Model.SachList)
            {
                <div class="col">
                    <a asp-page="/ChiTietSachView" asp-route-token="@Model.EncryptId(item.IdSach)" class="text-decoration-none">
                        <div class="book-product-card shadow-sm">
                            <div class="book-product-img-wrap">
                                <img src="@(string.IsNullOrEmpty(item.AnhBiaUrl) ? HinhAnhPaths.WebDefaultBookCover : item.AnhBiaUrl)"
                                     class="book-product-img" alt="@item.TieuDe"
                                     onerror="this.onerror=null; this.src='@HinhAnhPaths.WebDefaultBookCover'">
                            </div>
                            <div class="card-body text-center p-3 d-flex flex-column">
                                <h6 class="text-dark fw-bold mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.4em; line-height: 1.2;">@item.TieuDe</h6>
                                <span class="text-danger fw-bold mt-auto">@item.GiaBia.ToString("N0") đ</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else if (string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="text-center py-5">
            <div class="p-5 bg-white rounded-4 shadow-sm border d-inline-block">
                <span class="material-symbols-outlined text-muted mb-3" style="font-size: 5rem;">search_off</span>
                <h5 class="fw-bold" style="color: var(--cf-dark-brown);">Không tìm thấy sách</h5>
                <p class="text-muted">Rất tiếc, chưa có cuốn sách nào khớp với tiêu chí của bạn.</p>
                <a asp-page="/ThuVienSachView" class="btn btn-outline-primary mt-2 fw-bold" style="border-radius: 10px;">
                    <span class="material-symbols-outlined align-middle me-1">arrow_back</span> Quay lại Thư viện
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const $wrapper = $('#page-description-wrapper');
            if ($wrapper.length === 0) return;

            const $content = $wrapper.find('p');
            const $btn = $('#toggle-page-description');

            const lineHeight = parseFloat($content.css("line-height")) || 24;
            const maxHeight = lineHeight * 2; // Ẩn bớt nếu quá 2 dòng

            if ($content[0].scrollHeight > (maxHeight + 5)) {
                $btn.show();
            }

            $btn.on("click", function () {
                const expanded = $wrapper.hasClass('description-expanded');
                $wrapper.toggleClass('description-expanded description-truncated');
                
                if (expanded) {
                    $btn.html('Đọc tiếp <span class="material-symbols-outlined align-middle" style="font-size: 1.2rem;">expand_more</span>');
                } else {
                    $btn.html('Thu gọn <span class="material-symbols-outlined align-middle" style="font-size: 1.2rem;">expand_less</span>');
                }
            });
        });
    </script>
}