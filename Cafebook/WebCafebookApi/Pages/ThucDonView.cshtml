@page "/san-pham"
@inject Microsoft.AspNetCore.DataProtection.IDataProtectionProvider ProtectorProvider
@{
    var protector = ProtectorProvider.CreateProtector("Cafebook.SanPham.Id");
}
@model WebCafebookApi.Pages.ThucDonViewModel
@using CafebookModel.Utils
@{
    ViewData["Title"] = "Thực Đơn";
    
    var routeData = new Dictionary<string, string?>
    {
        { "LoaiId", Model.LoaiId?.ToString() },
        { "Search", Model.Search },
        { "SortBy", Model.SortBy },
        { "GiaMin", Model.GiaMin?.ToString() },
        { "GiaMax", Model.GiaMax?.ToString() }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/ThucDonView.css" asp-append-version="true" />
}

<div class="container mt-4 mb-5">
    <div class="menu-header-section shadow-sm">
        <h1 class="fw-bold" style="color: var(--cf-dark-brown);">@ViewData["Title"]</h1>
        <p class="lead text-muted mb-0 position-relative z-1">Hương vị tuyệt hảo, đánh thức mọi giác quan.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger shadow-sm rounded-3 d-flex align-items-center">
            <span class="material-symbols-outlined me-2">error</span>
            @Model.ErrorMessage
        </div>
    }

    <div class="row">
        <div class="col-lg-3 mb-4">
            <form method="get" asp-page="/ThucDonView">
                <div class="card sticky-top menu-filter-card">
                    <div class="card-header d-flex align-items-center">
                        <span class="material-symbols-outlined me-2">tune</span>
                        <h5 class="mb-0 fw-bold">Tìm & Lọc</h5>
                    </div>
                    <div class="card-body p-4">
                        
                        <label class="form-label fw-bold" style="color: var(--cf-dark-brown);">Tìm theo tên</label>
                        <div class="menu-input-group">
                            <span class="material-symbols-outlined">search</span>
                            <input asp-for="Search" class="menu-input" placeholder="Nhập tên món...">
                        </div>

                        <label class="form-label fw-bold" style="color: var(--cf-dark-brown);">Danh mục</label>
                        <div class="menu-input-group">
                            <span class="material-symbols-outlined">category</span>
                            <select asp-for="LoaiId" asp-items="@Model.LoaiSanPhamsList" class="menu-select"></select>
                        </div>

                        <label class="form-label fw-bold" style="color: var(--cf-dark-brown);">Khoảng giá</label>
                        <div class="input-group mb-4 shadow-sm" style="border-radius: 10px; overflow: hidden;">
                            <input asp-for="GiaMin" class="form-control border-0 bg-light py-2 px-3" placeholder="Từ" type="number" step="1000">
                            <span class="input-group-text border-0 bg-light text-muted">-</span>
                            <input asp-for="GiaMax" class="form-control border-0 bg-light py-2 px-3" placeholder="Đến" type="number" step="1000">
                        </div>

                        <label class="form-label fw-bold" style="color: var(--cf-dark-brown);">Sắp xếp</label>
                        <div class="menu-input-group">
                            <span class="material-symbols-outlined">sort</span>
                            <select asp-for="SortBy" class="menu-select">
                                <option value="ten_asc">Tên (A-Z)</option>
                                <option value="ten_desc">Tên (Z-A)</option>
                                <option value="gia_asc">Giá (Thấp đến Cao)</option>
                                <option value="gia_desc">Giá (Cao đến Thấp)</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3 py-2 fw-bold" style="border-radius: 10px;">
                            <span class="material-symbols-outlined align-middle me-1">check_circle</span> ÁP DỤNG
                        </button>
                        <a asp-page="/ThucDonView" class="btn btn-outline-secondary w-100 py-2" style="border-radius: 10px;">
                            <span class="material-symbols-outlined align-middle me-1">refresh</span> Đặt lại
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-9">
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
                @if (Model.MenuResult?.Items != null && Model.MenuResult.Items.Any())
                {
                    @foreach (var item in Model.MenuResult.Items)
                    {
                        <div class="col">
                            <a asp-page="/ChiTietSanPhamView" asp-route-token="@Model.EncryptId(item.IdSanPham)" class="text-decoration-none">
                                <div class="menu-product-card shadow-sm">
                                    <div class="menu-product-img-wrap">
                                        <img src="@(string.IsNullOrEmpty(item.AnhSanPhamUrl) ? HinhAnhPaths.WebDefaultFoodIcon : item.AnhSanPhamUrl)"
                                             class="menu-product-img" alt="@item.TenSanPham"
                                             onerror="this.onerror=null; this.src='@HinhAnhPaths.WebDefaultFoodIcon'">
                                        
                                        <div class="menu-price-tag">@item.DonGia.ToString("N0") đ</div>
                                    </div>
                                    <div class="menu-product-body">
                                        <h5 class="card-title text-dark fw-bold mb-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            @item.TenSanPham
                                        </h5>
                                        <p class="card-text text-muted small mt-auto d-flex align-items-center">
                                            <span class="material-symbols-outlined me-1" style="font-size: 1rem;">local_cafe</span>
                                            @item.TenLoaiSP
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <div class="p-5 bg-white rounded-4 shadow-sm border">
                            <span class="material-symbols-outlined text-muted mb-3" style="font-size: 5rem;">search_off</span>
                            <h4 class="fw-bold" style="color: var(--cf-dark-brown);">Không tìm thấy món ăn</h4>
                            <p class="text-muted fs-6">Thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác nhé.</p>
                        </div>
                    </div>
                }
            </div>

            @if (Model.MenuResult != null && Model.MenuResult.TotalPages > 1)
            {
                <nav class="mt-5 d-flex justify-content-center">
                    <ul class="pagination pagination-lg shadow-sm" style="border-radius: 12px; overflow: hidden;">
                        <li class="page-item @(Model.MenuResult.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link text-dark" asp-all-route-data="routeData" asp-route-PageNum="@(Model.MenuResult.CurrentPage - 1)">
                                <span class="material-symbols-outlined align-middle">chevron_left</span>
                            </a>
                        </li>
                        
                        @for (int i = 1; i <= Model.MenuResult.TotalPages; i++)
                        {
                            <li class="page-item @(Model.MenuResult.CurrentPage == i ? "active" : "")">
                                <a class="page-link @(Model.MenuResult.CurrentPage == i ? "bg-primary border-primary text-white" : "text-dark")"
                                   asp-all-route-data="routeData" asp-route-PageNum="@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.MenuResult.CurrentPage == Model.MenuResult.TotalPages ? "disabled" : "")">
                            <a class="page-link text-dark" asp-all-route-data="routeData" asp-route-PageNum="@(Model.MenuResult.CurrentPage + 1)">
                                <span class="material-symbols-outlined align-middle">chevron_right</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>