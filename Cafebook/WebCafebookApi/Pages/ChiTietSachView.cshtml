@page "/chi-tiet-sach/{token?}"
@model WebCafebookApi.Pages.ChiTietSachViewModel
@using CafebookModel.Utils
@{
    ViewData["Title"] = Model.Sach?.TieuDe ?? "Chi Tiết Sách";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ChiTietSachView.css" asp-append-version="true" />
}

<div class="container mt-5 mb-5">
    @if (Model.Sach != null)
    {
        <div class="row book-detail-card p-4 gy-4">
            <div class="col-lg-4">
                <div class="book-cover-container text-center">
                    <img src="@(string.IsNullOrEmpty(Model.Sach.AnhBiaUrl) ? HinhAnhPaths.WebDefaultBookCover : Model.Sach.AnhBiaUrl)"
                         class="book-cover-img" alt="@Model.Sach.TieuDe"
                         onerror="this.onerror=null; this.src='@HinhAnhPaths.WebDefaultBookCover'">
                </div>
            </div>

            <div class="col-lg-8 ps-lg-5 d-flex flex-column">
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-page="/TrangChuView" class="text-decoration-none" style="color: var(--cf-brown);"><span class="material-symbols-outlined align-text-bottom fs-6">home</span></a></li>
                        <li class="breadcrumb-item"><a asp-page="/ThuVienSachView" class="text-decoration-none" style="color: var(--cf-brown);">Thư Viện Sách</a></li>
                        <li class="breadcrumb-item active text-truncate" style="max-width: 200px;">@Model.Sach.TieuDe</li>
                    </ol>
                </nav>

                <h1 class="fw-bold mb-3" style="color: var(--cf-dark-brown); font-size: 2.2rem;">@Model.Sach.TieuDe</h1>

                <p class="fs-5 mb-4 text-muted">
                    <span class="material-symbols-outlined align-middle me-1">edit_square</span> Tác giả:
                    @if (Model.Sach.TacGias?.Any() == true)
                    {
                        foreach (var tg in Model.Sach.TacGias)
                        {
                            <a asp-page="/TimKiemSachView" asp-route-idTacGia="@tg.IdTacGia" class="text-dark fw-semibold text-decoration-none hover-orange">@tg.TenTacGia</a>
                            @(tg != Model.Sach.TacGias.Last() ? ", " : "")
                        }
                    }
                    else
                    {
                        <span>(Chưa cập nhật)</span>
                    }
                </p>

                <h2 class="text-danger fw-bolder mb-4">
                    @Model.Sach.GiaBia.ToString("N0") đ <small class="text-muted fs-6 fw-normal">(Tiền cọc)</small>
                </h2>

                <hr class="mb-4" />

                <div class="rent-box-card mt-auto">
                    <h5 class="fw-bold mb-3" style="color: var(--cf-dark-brown);">Quy trình mượn sách</h5>
                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                        <span class="fs-6 fw-semibold text-muted">Tình trạng hiện tại:</span>
                        @if (Model.Sach.SoLuongCoSan > 0)
                        {
                            <strong class="text-success fs-5">
                                <span class="material-symbols-outlined align-text-bottom">check_circle</span> Còn @Model.Sach.SoLuongCoSan cuốn
                            </strong>
                        }
                        else
                        {
                            <strong class="text-secondary fs-5">
                                <span class="material-symbols-outlined align-text-bottom">block</span> Đã mượn hết
                            </strong>
                        }
                    </div>
                    
                    <button type="button" class="btn btn-primary btn-lg w-100 fw-bold d-flex justify-content-center align-items-center shadow-sm" disabled style="border-radius: 12px;">
                        <span class="material-symbols-outlined me-2">menu_book</span> Thuê sách (Đang phát triển)
                    </button>
                    <small class="text-muted d-block text-center mt-3"><i class="fa-solid fa-circle-info me-1"></i>Vui lòng liên hệ trực tiếp tại quầy để làm thủ tục mượn sách.</small>
                </div>
            </div>
        </div>

        <ul class="nav nav-tabs book-tabs mb-4">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#descriptionTab">Mô Tả Sách</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#stockTab">Thông Tin Kho</a>
            </li>
        </ul>

        <div class="tab-content bg-white p-4 rounded-4 shadow-sm border mb-5">
            <div class="tab-pane fade show active" id="descriptionTab">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="fw-bold text-muted mb-2">Thể loại</h6>
                        @if (Model.Sach.TheLoais?.Any() == true)
                        {
                            foreach (var tl in Model.Sach.TheLoais)
                            {
                                <a asp-page="/TimKiemSachView" asp-route-idTheLoai="@tl.IdTheLoai" class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 text-decoration-none me-1 mb-1 px-3 py-2">@tl.TenTheLoai</a>
                            }
                        }
                    </div>
                    <div class="col-md-6 mt-3 mt-md-0">
                        <h6 class="fw-bold text-muted mb-2">Nhà xuất bản</h6>
                        @if (Model.Sach.NhaXuatBans?.Any() == true)
                        {
                            foreach (var nxb in Model.Sach.NhaXuatBans)
                            {
                                <a asp-page="/TimKiemSachView" asp-route-idNXB="@nxb.IdNhaXuatBan" class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 text-decoration-none me-1 mb-1 px-3 py-2">@nxb.TenNhaXuatBan</a>
                            }
                        }
                    </div>
                </div>

                <h5 class="fw-bold mt-4 mb-3" style="color: var(--cf-dark-brown);">Nội dung tóm tắt</h5>
                <div id="description-wrapper" class="description-truncated">
                    <p class="fs-6" style="line-height: 1.8; color: var(--cf-text); white-space: pre-wrap;">@(Model.Sach.MoTa ?? "Chưa có bài giới thiệu cho cuốn sách này.")</p>
                </div>
                <a id="toggle-description" href="javascript:void(0);" class="text-decoration-none fw-bold" style="color: var(--cf-orange); display:none;">Đọc tiếp <span class="material-symbols-outlined align-middle" style="font-size: 1.2rem;">expand_more</span></a>
            </div>

            <div class="tab-pane fade" id="stockTab">
                <ul class="list-group list-group-flush fs-6">
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted"><span class="material-symbols-outlined align-middle me-2">push_pin</span> Vị trí kệ sách:</span>
                        <strong class="text-dark">@(Model.Sach.ViTri ?? "Chưa sắp xếp")</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted"><span class="material-symbols-outlined align-middle me-2">inventory_2</span> Tổng số lượng nhập:</span>
                        <strong class="text-dark">@Model.Sach.TongSoLuong cuốn</strong>
                    </li>
                </ul>
            </div>
        </div>

        @if (Model.Sach.GoiY?.Any() == true)
        {
            <h3 class="fw-bold mb-4" style="color: var(--cf-dark-brown); border-bottom: 2px solid var(--cf-orange); display: inline-block; padding-bottom: 5px;">
                Sách cùng chủ đề
            </h3>
            <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-3">
                @foreach (var item in Model.Sach.GoiY)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; overflow: hidden; transition: transform 0.3s;">
                            <a asp-page="/ChiTietSachView" asp-route-token="@Model.EncryptId(item.IdSach)" class="text-decoration-none">
                                <div style="padding: 10px; background: var(--cf-cream);">
                                    <img src="@(string.IsNullOrEmpty(item.AnhBiaUrl) ? HinhAnhPaths.WebDefaultBookCover : item.AnhBiaUrl)"
                                         class="card-img-top shadow-sm" style="aspect-ratio: 2/3; object-fit: cover; border-radius: 4px;"
                                         onerror="this.onerror=null; this.src='@HinhAnhPaths.WebDefaultBookCover'" />
                                </div>
                                <div class="card-body text-center p-3">
                                    <h6 class="text-dark fw-bold mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.4em;">@item.TieuDe</h6>
                                    <span class="text-danger fw-bold">@item.GiaBia.ToString("N0") đ</span>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <div class="alert alert-danger shadow-sm p-5 rounded-4 d-inline-block">
                <span class="material-symbols-outlined text-danger mb-3" style="font-size: 4rem;">search_off</span>
                <h4 class="fw-bold">@Model.ErrorMessage</h4>
                <a asp-page="/ThuVienSachView" class="btn btn-outline-danger mt-3">Quay lại Thư viện sách</a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(function () {
            // Logic "Đọc thêm / Thu gọn" mô tả
            const $wrapper = $('#description-wrapper');
            const $content = $wrapper.find('p');
            const $btn = $('#toggle-description');

            const lineHeight = parseFloat($content.css("line-height"));
            const maxHeight = lineHeight * 4; // Cắt dòng thứ 4

            if ($content[0].scrollHeight > (maxHeight + 5)) {
                $btn.show();
            }

            $btn.on("click", function () {
                const expanded = $wrapper.hasClass('description-expanded');
                $wrapper.toggleClass('description-expanded description-truncated');
                
                if (expanded) {
                    $btn.html('Đọc tiếp <span class="material-symbols-outlined align-middle" style="font-size: 1.2rem;">expand_more</span>');
                } else {
                    $btn.html('Thu gọn <span class="material-symbols-outlined align-middle" style="font-size: 1.2rem;">expand_less</span>');
                }
            });
        });
    </script>
}