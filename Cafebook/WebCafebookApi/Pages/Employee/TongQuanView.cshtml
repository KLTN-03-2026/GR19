@page "/nhan-vien/tong-quan"
@model WebCafebookApi.Pages.Employee.TongQuanViewModel
@using CafebookModel.Utils

@{
    ViewData["Title"] = "Tổng quan";
    Layout = "_Layout_Employee";
}

@section Styles {
    <link rel="stylesheet" href="~/css/TongQuan.css" asp-append-version="true" />
}

<div class="tqnv-container fade-in-up">
    <div class="row g-4">
        <!-- Thông tin cá nhân -->
        <div class="col-lg-5 col-xl-4">
            <div class="tqnv-card tqnv-profile-card">
                <div class="tqnv-profile-header">
                    <!-- Khu vực thay đổi Avatar -->
                    <div class="tqnv-avatar-wrapper position-relative" style="cursor: pointer;" onclick="document.getElementById('avatarInput').click();">
                        <img src="@(Model.DashboardData.ThongTin.AnhDaiDien ?? HinhAnhPaths.WebDefaultAvatar)"
                             alt="Avatar" class="tqnv-avatar-large"
                             onerror="this.onerror=null; this.src='@HinhAnhPaths.WebDefaultAvatar';">
                        <div class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-1" style="transform: translate(20%, -20%);">
                            <span class="material-symbols-outlined icon-small">photo_camera</span>
                        </div>
                    </div>
                    
                    <form id="avatarForm" method="post" asp-page-handler="UploadAvatar" enctype="multipart/form-data" class="d-none">
                        <input type="file" id="avatarInput" name="avatarFile" accept="image/jpeg, image/png" onchange="document.getElementById('avatarForm').submit();" />
                    </form>

                    <h3 class="tqnv-profile-name">@(Model.DashboardData.ThongTin.HoTen ?? "Đang cập nhật")</h3>
                    
                    <div class="tqnv-badges-container">
                        <span class="tqnv-badge tqnv-role-badge">
                            <span class="material-symbols-outlined icon-small">work</span>
                            @Model.DashboardData.ThongTin.TenVaiTro
                        </span>
                        
                        @if (Model.DashboardData.ThongTin.TrangThaiLamViec == "Đang làm việc")
                        {
                            <span class="tqnv-badge tqnv-status-active">
                                <span class="material-symbols-outlined icon-small">check_circle</span>
                                Đang làm việc
                            </span>
                        }
                        else
                        {
                            <span class="tqnv-badge tqnv-status-inactive">
                                <span class="material-symbols-outlined icon-small">cancel</span>
                                @Model.DashboardData.ThongTin.TrangThaiLamViec
                            </span>
                        }
                    </div>
                </div>

                <div class="tqnv-profile-details">
                    <div class="tqnv-detail-item">
                        <div class="tqnv-icon-box"><span class="material-symbols-outlined">mail</span></div>
                        <div class="tqnv-detail-text">
                            <span class="tqnv-detail-label">Email</span>
                            <span class="tqnv-detail-value">@(Model.DashboardData.ThongTin.Email ?? "Chưa cập nhật")</span>
                        </div>
                    </div>
                    <div class="tqnv-detail-item">
                        <div class="tqnv-icon-box"><span class="material-symbols-outlined">call</span></div>
                        <div class="tqnv-detail-text">
                            <span class="tqnv-detail-label">Số điện thoại</span>
                            <span class="tqnv-detail-value">@(Model.DashboardData.ThongTin.SoDienThoai ?? "Chưa cập nhật")</span>
                        </div>
                    </div>
                    <div class="tqnv-detail-item">
                        <div class="tqnv-icon-box"><span class="material-symbols-outlined">badge</span></div>
                        <div class="tqnv-detail-text">
                            <span class="tqnv-detail-label">Mã nhân sự</span>
                            <span class="tqnv-detail-value">#@Model.DashboardData.ThongTin.IdNhanVien</span>
                        </div>
                    </div>
                </div>
                
                <div class="text-center mt-4 d-flex gap-2">
                    <button class="btn tqnv-btn-outline w-100 material-ripple" data-bs-toggle="modal" data-bs-target="#editInfoModal">
                        <span class="material-symbols-outlined me-2">edit_square</span> Cập nhật
                    </button>
                    <button class="btn btn-outline-danger w-100 material-ripple" data-bs-toggle="modal" data-bs-target="#changePassModal">
                        <span class="material-symbols-outlined me-2">key</span> Đổi Pass
                    </button>
                </div>
            </div>
        </div>

        <!-- Cột thông báo (giữ nguyên logic gốc) -->
        <div class="col-lg-7 col-xl-8">
            <div class="tqnv-card tqnv-notification-card">
                <div class="tqnv-card-header">
                    <h4 class="tqnv-card-title">
                        <span class="material-symbols-outlined me-2 text-accent">notifications_active</span>
                        Thông báo hệ thống
                    </h4>
                    <span class="tqnv-noti-count">@Model.DashboardData.DanhSachThongBao.Count(x => !x.DaXem) thông báo mới</span>
                </div>
                
                <div class="tqnv-notification-list">
                    @if (Model.DashboardData.DanhSachThongBao.Any())
                    {
                        foreach (var item in Model.DashboardData.DanhSachThongBao)
                        {
                            <div class="tqnv-noti-item @(item.DaXem ? "read" : "unread")">
                                <div class="tqnv-noti-icon-wrapper">
                                    <span class="material-symbols-outlined">@(item.DaXem ? "drafts" : "mail")</span>
                                </div>
                                <div class="tqnv-noti-content">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h6 class="tqnv-noti-title">@item.LoaiThongBao</h6>
                                        <span class="tqnv-noti-time">@item.ThoiGianTao.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                    <p class="tqnv-noti-desc">@item.NoiDung</p>
                                    <div class="tqnv-noti-footer">
                                        <span class="material-symbols-outlined icon-tiny">person</span> Gửi bởi: @item.TenNhanVienTao
                                    </div>
                                </div>
                                @if (!item.DaXem)
                                {
                                    <div class="tqnv-unread-indicator"></div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="tqnv-empty-state">
                            <div class="tqnv-empty-icon-circle">
                                <span class="material-symbols-outlined tqnv-empty-icon">coffee</span>
                            </div>
                            <h5>Mọi thứ đều ổn!</h5>
                            <p>Bạn không có thông báo mới nào vào lúc này.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa thông tin -->
<div class="modal fade" id="editInfoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="UpdateInfo">
                <div class="modal-header">
                    <h5 class="modal-title">Cập nhật thông tin cá nhân</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Họ tên (*)</label>
                        <input type="text" asp-for="UpdateModel.HoTen" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Số điện thoại (*)</label>
                        <input type="text" asp-for="UpdateModel.SoDienThoai" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" asp-for="UpdateModel.Email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Địa chỉ</label>
                        <input type="text" asp-for="UpdateModel.DiaChi" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Đổi mật khẩu -->
<div class="modal fade" id="changePassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="ChangePassword">
                <div class="modal-header">
                    <h5 class="modal-title">Đổi mật khẩu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Mật khẩu cũ (*)</label>
                        <input type="password" asp-for="PasswordModel.MatKhauCu" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Mật khẩu mới (*)</label>
                        <input type="password" asp-for="PasswordModel.MatKhauMoi" class="form-control" minlength="6" required />
                        <small class="text-muted">Ít nhất 6 ký tự</small>
                    </div>
                    <div class="mb-3">
                        <label>Xác nhận mật khẩu mới (*)</label>
                        <input type="password" asp-for="PasswordModel.XacNhanMatKhau" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-danger">Xác nhận đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.modal').appendTo('body');

            var errorMsg = '@Html.Raw(TempData["ErrorMessage"]?.ToString()?.Replace("'", "\\'"))';
            var successMsg = '@Html.Raw(TempData["SuccessMessage"]?.ToString()?.Replace("'", "\\'"))';
            
            if (errorMsg && errorMsg.trim() !== '') {
                Swal.fire({
                    icon: 'error',
                    title: 'Đã xảy ra lỗi',
                    text: errorMsg,
                    confirmButtonColor: '#D84315'
                });
            }

            if (successMsg && successMsg.trim() !== '') {
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công',
                    text: successMsg,
                    confirmButtonColor: '#28a745'
                });
            }
        });
    </script>
}