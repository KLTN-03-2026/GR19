@page "/gio-hang"
@model WebCafebookApi.Pages.GioHangViewPageModel
@using CafebookModel.Utils
@{
    ViewData["Title"] = "Giỏ hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/GioHang.css" asp-append-version="true" />
}

<div class="gh-wrapper container py-5">

    <div class="gh-header-section">
        <h2 class="fw-bold mb-2">GIỎ HÀNG CỦA BẠN</h2>
        <p class="text-muted m-0 position-relative" style="z-index: 2;">
            Đang có <span class="fw-bold text-danger fs-5">@Model.Cart.TongSoLuong</span> món trong danh sách
        </p>
    </div>

    @if (!Model.Cart.Items.Any())
    {
        <div class="gh-empty card border-0 shadow-sm text-center p-5 mt-4">
            <div class="card-body">
                <span class="material-symbols-outlined display-1 text-muted opacity-25 mb-3">shopping_cart_off</span>
                <h4 class="fw-bold text-dark">Giỏ hàng đang trống</h4>
                <p class="text-muted mb-4">Bạn chưa chọn món nào. Hãy khám phá thêm thực đơn nhé!</p>
                <a href="@(Url.Page("/ThucDonView") ?? "/ThucDonView")" class="btn btn-brown px-5 py-3 rounded-pill fw-bold">XEM THỰC ĐƠN NGAY</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                @foreach (var item in Model.Cart.Items)
                {
                    <div class="gh-card card mb-3 border-0 shadow-sm overflow-hidden">
                        <div class="row g-0 h-100">
                            <div class="col-4 col-sm-3">
                                <div class="gh-img-container h-100">
                                    <img src="@item.HinhAnhUrl"
                                         alt="@item.TenSanPham"
                                         onerror="this.src='@HinhAnhPaths.WebDefaultFoodIcon'" />
                                </div>
                            </div>
                            
                            <div class="col-8 col-sm-9">
                                <div class="card-body p-3 p-md-4 d-flex flex-column justify-content-between h-100">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h5 class="fw-bold mb-1 text-dark gh-product-title">@item.TenSanPham</h5>
                                            @if (item.IsOutOfStock)
                                            {
                                                <p class="text-danger small mb-0" style="font-size: 0.8rem;">
                                                    <i class="material-symbols-outlined fs-6 align-middle">error</i> @item.OutOfStockMessage
                                                </p>
                                            }
                                            <p class="text-danger fw-bold mb-0">@item.DonGia.ToString("N0") đ</p>
                                        </div>
                                        <form method="post" asp-page-handler="Remove" class="m-0">
                                            <input type="hidden" name="id" value="@item.IdSanPham" />
                                            <button type="submit" class="btn-remove btn btn-link p-0 text-decoration-none" title="Xóa món">
                                                <span class="material-symbols-outlined fs-5">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                    
                                    <div class="d-flex align-items-center justify-content-between mt-auto pt-3">
                                        <div class="gh-qty-control d-flex align-items-center bg-light rounded-pill">
                                            <form method="post" asp-page-handler="Update" class="m-0">
                                                <input type="hidden" name="id" value="@item.IdSanPham" />
                                                <button type="submit" name="delta" value="-1" class="btn btn-qty">-</button>
                                            </form>
                                            <span class="mx-2 mx-md-3 fw-bold text-dark" style="min-width: 20px; text-align: center;">@item.SoLuong</span>
                                            <form method="post" asp-page-handler="Update" class="m-0">
                                                <input type="hidden" name="id" value="@item.IdSanPham" />
                                                <button type="submit" name="delta" value="1" class="btn btn-qty">+</button>
                                            </form>
                                        </div>
                                        <div class="text-end">
                                            <span class="fw-bold gh-total-price">@item.ThanhTien.ToString("N0") đ</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="gh-summary card border-0 shadow-sm sticky-top" style="top: 100px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 text-dark border-bottom pb-3">TÓM TẮT ĐƠN HÀNG</h5>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng phụ (@Model.Cart.TongSoLuong món)</span>
                            <span class="fw-bold">@Model.Cart.TongTienHang.ToString("N0") đ</span>
                        </div>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Phí giao hàng</span>
                            @if (Model.Cart.PhiGiaoHang > 0)
                            {
                                <span class="fw-bold">@Model.Cart.PhiGiaoHang.ToString("N0") đ</span>
                            }
                            else
                            {
                                <span class="text-success fw-bold">Miễn phí</span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Cart.MaKhuyenMaiApDung))
                        {
                            <div class="alert alert-success d-flex justify-content-between align-items-center p-2 mb-3">
                                <div>
                                    <span class="material-symbols-outlined fs-6 align-middle me-1">local_offer</span>
                                    <strong>@Model.Cart.MaKhuyenMaiApDung</strong>
                                </div>
                                <form method="post" asp-page-handler="RemovePromo" class="m-0">
                                    <button type="submit" class="btn-close" style="font-size: 0.6rem;"></button>
                                </form>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-success">Giảm giá</span>
                                <span class="fw-bold text-success">-@Model.Cart.TienGiamGia.ToString("N0") đ</span>
                            </div>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-primary w-100 mb-3 d-flex align-items-center justify-content-center border-dashed" data-bs-toggle="modal" data-bs-target="#promoModal">
                                <span class="material-symbols-outlined me-2">confirmation_number</span>
                                Chọn mã khuyến mãi
                            </button>
                        }

                        <hr class="my-4" />
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 fw-bold text-dark">TỔNG TIỀN</span>
                            <span class="fs-4 fw-bold text-danger">@Model.Cart.TongTienThanhToan.ToString("N0") đ</span>
                        </div>
                        
                        <div class="alert alert-warning border-0 small mb-4 px-3 py-2 rounded-3">
                            <i class="material-symbols-outlined fs-6 align-middle me-1 text-warning">stars</i>
                            Tích lũy được <b class="text-dark">@( (int)(Model.Cart.TongTienHang / 10000) )</b> điểm sau đơn hàng này.
                        </div>

                        @if (!Model.Cart.CanCheckout)
                        {
                            <div class="alert alert-danger border-0 small mb-3 px-3 py-2 rounded-3 text-center fw-bold">
                                <i class="material-symbols-outlined fs-6 align-middle me-1">warning</i>
                                @Model.Cart.CheckoutWarning
                            </div>
                            <button class="btn btn-secondary w-100 py-3 rounded-pill fw-bold fs-6" disabled>
                                TẠM NGƯNG THANH TOÁN
                            </button>
                        }
                        else
                        {
                            <a asp-page="/Account/ThanhToanView" class="btn btn-brown w-100 py-3 rounded-pill fw-bold fs-6">
                                TIẾN HÀNH THANH TOÁN
                            </a>
                        }
                        <a asp-page="/ThucDonView" class="btn btn-light text-muted w-100 mt-3 py-2 border rounded-pill fw-semibold">
                            <i class="fas fa-arrow-left me-2"></i>Tiếp tục mua thêm
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="promoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold text-dark">Ưu đãi của bạn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" style="background-color: #f8f9fa;">
                @if (Model.AvailablePromotions.Any())
                {
                    foreach (var km in Model.AvailablePromotions)
                    {
                        <div class="coupon-card @(km.IsEligible ? "eligible" : "ineligible") mb-3">
                            <div class="coupon-left">
                                <span class="material-symbols-outlined display-4">redeem</span>
                            </div>
                            <div class="coupon-right">
                                <h6 class="fw-bold mb-1">@km.TenChuongTrinh</h6>
                                <p class="small text-muted mb-2">@km.DieuKienApDung</p>
                                
                                @if (km.IsEligible)
                                {
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span class="text-success fw-bold">-@km.CalculatedDiscount.ToString("N0") đ</span>
                                        <form method="post" asp-page-handler="ApplyPromo" class="m-0">
                                            <input type="hidden" name="maKhuyenMai" value="@km.MaKhuyenMai" />
                                            <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold">Dùng ngay</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-danger p-2 m-0 mt-2 small" style="font-size: 0.75rem;">
                                        <i class="fas fa-exclamation-circle"></i> @km.IneligibilityReason
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4">
                        <span class="material-symbols-outlined fs-1 text-muted mb-2 opacity-50">sentiment_dissatisfied</span>
                        <p class="text-muted m-0">Hiện chưa có chương trình khuyến mãi nào phù hợp.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>