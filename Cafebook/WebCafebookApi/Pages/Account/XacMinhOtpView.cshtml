@page "/xac-minh-otp"
@model WebCafebookApi.Pages.Account.XacMinhOtpViewModel
@{
    ViewData["Title"] = "Xác thực OTP";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cafebook</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/DangKyView.css" asp-append-version="true" />
    
    <style>
            .cb-input[readonly] {
                background-color: #f8f9fa !important; 
                color: #6c757d;
                cursor: not-allowed;
                border-bottom: 1px solid #ced4da;
            }

                .cb-input[readonly]:focus {
                    border-bottom: 1px solid #ced4da; 
                }
    </style>
</head>

<body class="cb-register-body">
    <div class="cb-register-wrapper">
        <div class="cb-register-container">

            <div class="cb-register-brand">
                <img src="/images/logo.png" alt="Cafebook Logo" class="cb-register-logo" onerror="this.src='/images/default-avatar.png';">
                <div class="cb-brand-text">
                    <h1 class="cb-brand-title">Cafebook</h1>
                    <p class="cb-brand-slogan">Xác thực bảo mật</p>
                </div>
            </div>

            <div class="cb-register-form-area">
                <h2 class="cb-register-title">Xác thực OTP</h2>
                
                <div class="alert alert-info p-3 mb-4" style="background-color: #F4F8FF; border-color: #E8F0FE; color: var(--cf-dark-brown);">
                    <i class="material-symbols-outlined" style="vertical-align: bottom;">celebration</i>
                    @Model.OtpMessage
                </div>
                <p class="cb-register-subtitle">Vui lòng kiểm tra lại thông tin và nhập mã OTP (hiệu lực 5 phút).</p>

                <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small"></div>

                    <input type="hidden" asp-for="Input.TempId" />
                    <input type="hidden" asp-for="Input.TempPassword" />

                    <div class="cb-input-group">
                        <span class="material-symbols-outlined cb-input-icon opacity-50">mail</span>
                        <input asp-for="Input.EditableEmail" class="cb-input" placeholder=" " readonly />
                        <label asp-for="Input.EditableEmail" class="cb-label">Email xác thực</label>
                    </div>

                    <div class="cb-input-group">
                        <span class="material-symbols-outlined cb-input-icon opacity-50">phone</span>
                        <input asp-for="Input.EditablePhone" class="cb-input" placeholder=" " readonly />
                        <label asp-for="Input.EditablePhone" class="cb-label">Số điện thoại</label>
                    </div>

                    <div class="cb-input-group mt-4">
                        <span class="material-symbols-outlined cb-input-icon text-warning">key</span>
                        <input asp-for="Input.OtpCode" class="cb-input fw-bold text-center" placeholder=" " maxlength="6" style="letter-spacing: 10px; font-size: 1.5rem;" />
                        <label asp-for="Input.OtpCode" class="cb-label">Nhập mã OTP 6 số</label>
                        <span asp-validation-for="Input.OtpCode" class="text-danger small mt-1 d-block w-100"></span>
                    </div>

                    <button type="submit" class="cb-btn-register mt-4 text-uppercase" style="padding: 1rem; font-size: 1.1rem; letter-spacing: 1px;">
                        XÁC NHẬN BẢO MẬT & ĐĂNG KÝ
                    </button>
                    <div class="text-center mt-3 mb-4">
                        <span class="text-muted small">Chưa nhận được mã?</span>
                        <button type="button" id="btnResendOtp" class="btn btn-link p-0 text-decoration-none small fw-bold ms-1" style="color: #9E9E9E;" disabled>
                            Gửi lại mã (<span id="otpCountdown">60</span>s)
                        </button>
                    </div>
                    <div class="text-center mt-3">
                        <a asp-page="/account/DangKyView" class="cb-login-link text-muted small"><i class="material-symbols-outlined align-middle" style="font-size: 1.1rem;">arrow_back</i> Quay lại sửa thông tin</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
            document.addEventListener("DOMContentLoaded", function () {
                let timeLeft = 60;
                let countdownTimer;
                const btnResend = document.getElementById('btnResendOtp');
        
                function startCountdown() {
                    timeLeft = 60;
                    btnResend.disabled = true;
                    btnResend.style.color = '#9E9E9E'; 
                    btnResend.innerHTML = `Gửi lại mã (<span id="otpCountdown">${timeLeft}</span>s)`;

                    countdownTimer = setInterval(() => {
                        timeLeft--;
                        document.getElementById('otpCountdown').innerText = timeLeft;

                        if (timeLeft <= 0) {
                            clearInterval(countdownTimer);
                            btnResend.disabled = false;
                            btnResend.style.color = '#D84315'; 
                            btnResend.innerHTML = 'Gửi lại mã ngay';
                        }
                    }, 1000);
                }

                startCountdown();

                btnResend.addEventListener('click', function () {
                    if (!this.disabled) {
                        alert("Yêu cầu gửi lại mã đã được thực thi!");
                
                        startCountdown();
                                    }
                });
            });
    </script>
</body>
</html>
