@page "/khach-hang/ho-tro/"
@model WebCafebookApi.Pages.Account.HoTroKHViewModel
@{
    ViewData["Title"] = "Hỗ trợ (Thành Viên)"; Layout = "_Layout";
}
@section Styles {
    <link href="~/css/HoTroKH.css" rel="stylesheet" />
}

<div class="container my-5">
    <div class="htkh-layout">
        <div class="htkh-sidebar">
            <div class="htkh-sidebar-head">
                <button class="htkh-btn-new" id="btnNewChat">+ Cuộc trò chuyện mới</button>
            </div>
            <div class="htkh-sessions" id="sessionList"></div>
        </div>

        <div class="htkh-main">
            <div class="htkh-history" id="chat-history"></div>
            
            <form id="chatForm" class="htkh-form">
                <input type="hidden" id="JwtToken" value="@Model.JwtToken" />
                <input type="hidden" id="IdKhach" value="@Model.HoTroData.IdKhachHang" />
                <input type="text" id="chatMessageInput" class="htkh-input" placeholder="Nhập câu hỏi..." autocomplete="off" required />
                <button type="submit" class="htkh-btn"><span class="material-symbols-outlined">send</span></button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const apiBaseUrl = '@Model.ApiBaseUrl'.replace(/\/$/, "");
        
        $(document).ready(function () {
        const idKhachHang = $('#IdKhach').val();
        const jwtToken = $('#JwtToken').val();
        const headers = { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwtToken };
            
        // 1. FIX LỖI: Luôn mở "Tab mới" khi vừa truy cập trang thay vì load lại phiên cũ
        let currentSessionId = 'session_' + Math.random().toString(36).substr(2, 9);
        let currentIdThongBao = null;
        let isRealtimeMode = false;
        let hubConnection = null;

        // Hàm tạo phiên chat mới hoàn toàn
        function createNewChat() {
        currentSessionId = 'session_' + Math.random().toString(36).substr(2, 9);
        currentIdThongBao = null;
        isRealtimeMode = false;
        if (hubConnection) {
        hubConnection.stop();
        hubConnection = null;
        }
        $('#chat-history').empty();
        drawMessage({ noiDung: "Chào bạn! Cafebook có thể hỗ trợ gì cho bạn?", thoiGian: new Date() }, false, false);
        loadSessions();
        }

        // Hàm chuyển đổi giữa các phiên chat cũ
        async function switchSession(sessionId) {
        currentSessionId = sessionId;
        // Lưu ID này lại để API biết ta đang thao tác trên phiên nào
        localStorage.setItem('cf_kh_session_' + idKhachHang, currentSessionId);
        await loadHistory();
        loadSessions(); // Load lại để cập nhật class 'active' trên sidebar
        }

        async function loadSessions() {
        const res = await fetch(`${apiBaseUrl}/api/web/khachhang/hotro/sessions`, { headers });
        const sessions = await res.json();
        $('#sessionList').empty();
        sessions.forEach(s => {
        const badge = s.idThongBao > 0 ? `<span class="htkh-badge">Hỗ trợ</span>` : '';
        const item = $(`<div class="htkh-session-item ${s.sessionId === currentSessionId ? 'active' : ''}" data-id="${s.sessionId}">${s.title} ${badge}</div>`);
        item.on('click', () => switchSession(s.sessionId));
        $('#sessionList').append(item);
        });
        }

        $('#btnNewChat').on('click', createNewChat);

        function drawMessage(msg, isUser, isStaff = false) {
        const type = isUser ? 'user' : (isStaff ? 'staff' : 'bot');
        const icon = isUser ? 'person' : (isStaff ? 'support_agent' : 'smart_toy');
        let text = (msg.noiDung || '').replace(/\[BUTTON:\s*(.*?)\s*\|\s*(.*?)\]/g, "").replace(/\n/g, '<br />');
                        
        let timeObj = msg.thoiGian ? new Date(msg.thoiGian) : new Date();
        const time = timeObj.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                        
        $('#chat-history').append(`
        <div class="htkh-row ${type}">
        <div class="htkh-avatar ${type}"><span class="material-symbols-outlined">${icon}</span></div>
        <div class="htkh-content">
        <div class="htkh-bubble">${text}</div>
        <div class="htkh-time ${isUser ? 'text-end' : 'text-start'}">${time}</div>
        </div>
        </div>
        `);
        $('#chat-history').scrollTop($('#chat-history')[0].scrollHeight);
        }

        // NÂNG CẤP: Giao diện AI đang gõ
        function showTypingIndicator() {
        $('#chat-history').append(`
        <div class="htkh-row bot" id="ai-typing-indicator">
        <div class="htkh-avatar bot"><span class="material-symbols-outlined">smart_toy</span></div>
        <div class="htkh-content">
        <div class="htkh-bubble">
        <div class="typing-dots"><span>.</span><span>.</span><span>.</span></div>
        </div>
        </div>
        </div>
        `);
        $('#chat-history').scrollTop($('#chat-history')[0].scrollHeight);
        }

        function hideTypingIndicator() {
        $('#ai-typing-indicator').remove();
        }

        async function loadHistory() {
        const res = await fetch(`${apiBaseUrl}/api/web/khachhang/hotro/history?sessionId=${currentSessionId}`, { headers });
        const history = await res.json();
        $('#chat-history').empty();
                        
        if(history.length === 0) {
        drawMessage({ noiDung: "Chào bạn!", thoiGian: new Date() }, false, false);
        } else {
        history.forEach(msg => {
        if (msg.idThongBaoHoTro > 0) currentIdThongBao = msg.idThongBaoHoTro;
        drawMessage(msg, msg.loaiTinNhan === 'KhachHang', msg.loaiTinNhan === 'NhanVien');
        });
        if (currentIdThongBao) { isRealtimeMode = true; startSignalR(); } else isRealtimeMode = false;
        }
        }

        $('#chatForm').on('submit', async function(e) {
        e.preventDefault();
        const text = $('#chatMessageInput').val().trim();
        if (!text) return; // Không gửi nếu tin nhắn rỗng

        $('#chatMessageInput').val('').prop('disabled', true);
                        
        // NÂNG CẤP: Hiển thị NGAY LẬP TỨC tin nhắn của người dùng
        drawMessage({ noiDung: text, thoiGian: new Date() }, true, false);

        if (isRealtimeMode && hubConnection) {
        // Đang chat với nhân viên -> Gửi qua SignalR
        await hubConnection.invoke("SendMessageFromClient", `khach_${idKhachHang}`, text, parseInt(idKhachHang), currentSessionId, parseInt(currentIdThongBao));
        } else {
        // Đang chat với AI -> Hiển thị "AI đang gõ..."
        showTypingIndicator();

        try {
        const res = await fetch(`${apiBaseUrl}/api/web/khachhang/hotro/send`, {
        method: 'POST',
        headers,
        body: JSON.stringify({ noiDung: text, sessionId: currentSessionId })
        });
        const data = await res.json();
                                    
        // Ẩn hiệu ứng gõ khi nhận được phản hồi
        hideTypingIndicator();
                        
        // LƯU Ý: Không gọi drawMessage cho data.tinNhanCuaKhach nữa vì đã vẽ ở trên
                                    
        // Vẽ tin nhắn AI phản hồi
        if (data.tinNhanPhanHoi) {
        setTimeout(() => drawMessage(data.tinNhanPhanHoi, false, data.tinNhanPhanHoi.loaiTinNhan === 'NhanVien'), 100);
        }
                                    
        if (data.daChuyenNhanVien) {
        currentIdThongBao = data.idThongBaoHoTro;
        isRealtimeMode = true;
        startSignalR();
        }
        loadSessions();
        } catch (error) {
        hideTypingIndicator();
        drawMessage({ noiDung: "Lỗi kết nối hệ thống. Vui lòng thử lại.", thoiGian: new Date() }, false, false);
        }
        }
                
        // Mở lại ô input
        $('#chatMessageInput').prop('disabled', false).focus();
        });

        async function startSignalR() {
        if (hubConnection) return;
        hubConnection = new signalR.HubConnectionBuilder().withUrl(apiBaseUrl + "/chatHub").build();
                        
        hubConnection.on("ReceiveMessage", msg => {
        // Bỏ qua nếu tin nhắn trả về là của chính khách hàng (tránh bị vẽ 2 lần khi chat realtime)
        if (msg.loaiTinNhan !== 'KhachHang') {
        drawMessage(msg, false, msg.loaiTinNhan === 'NhanVien');
        }
        });
                        
        await hubConnection.start();
        await hubConnection.invoke("JoinGroup", `khach_${idKhachHang}`);
        }
                
        // Khởi tạo trạng thái ban đầu khi vào trang (Tab mới)
        loadSessions();
        drawMessage({ noiDung: "Chào bạn! Cafebook có thể hỗ trợ gì cho bạn?", thoiGian: new Date() }, false, false);
        });
    </script>
}