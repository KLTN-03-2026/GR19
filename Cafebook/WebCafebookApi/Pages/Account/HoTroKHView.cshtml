@page "/khach-hang/ho-tro/"
@model WebCafebookApi.Pages.Account.HoTroKHViewModel
@{
    ViewData["Title"] = "Hỗ trợ";
    Layout = "_Layout";
}
@section Styles {
    <link href="~/css/HoTroKH.css" rel="stylesheet" />
}

<div class="container my-5">
    <h3 class="fw-bold">@ViewData["Title"]</h3>
    <p class="text-muted">Xin chào! Bạn có thể hỏi AI bất kỳ thông tin nào về quán.</p>

    <div class="htkh-layout">
        <div class="htkh-sidebar">
            <div class="htkh-sidebar-head">
                <button class="htkh-btn-new" id="btnNewChat">+ Cuộc trò chuyện mới</button>
            </div>
            <div class="htkh-sessions" id="sessionList"></div>
        </div>

        <div class="htkh-main">
            <div class="htkh-history" id="chat-history"></div>
            
            <form id="chatForm" class="htkh-form">
                <input type="hidden" id="JwtToken" value="@Model.JwtToken" />
                <input type="hidden" id="IdKhach" value="@Model.HoTroData.IdKhachHang" />
                <input type="hidden" id="GuestSessionId" value="@Model.GuestSessionId" />
                
                <input type="text" id="chatMessageInput" class="htkh-input" placeholder="Nhập câu hỏi..." autocomplete="off" required />
                <button type="submit" class="htkh-btn" id="sendBtn"><span class="material-symbols-outlined">send</span></button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const apiBaseUrl = '@Model.ApiBaseUrl'.replace(/\/$/, "");

        $(document).ready(function () {
        const idKhachHang = $('#IdKhach').val();
        const jwtToken = $('#JwtToken').val();
        const initGuestSessionId = $('#GuestSessionId').val(); // Session từ lúc chưa đăng nhập
        const headers = { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwtToken };
            
        // --- FIX 2: ƯU TIÊN LOAD ĐOẠN CHAT VÃNG LAI KHI VỪA ĐĂNG NHẬP ---
        let handledGuest = localStorage.getItem('handled_guest_' + initGuestSessionId);
        let savedSession = localStorage.getItem('cf_kh_session_' + idKhachHang);
        let currentSessionId;

        if (initGuestSessionId && !handledGuest) {
        currentSessionId = initGuestSessionId;
        localStorage.setItem('handled_guest_' + initGuestSessionId, 'true'); // Đánh dấu đã xử lý
        localStorage.setItem('cf_kh_session_' + idKhachHang, currentSessionId);
        } else {
        currentSessionId = savedSession || initGuestSessionId || ('session_' + Math.random().toString(36).substr(2, 9));
        }

        let currentIdThongBao = null;
        let isRealtimeMode = false;
        let hubConnection = null;

        function createNewChat() {
        currentSessionId = 'session_' + Math.random().toString(36).substr(2, 9);
        currentIdThongBao = null;
        isRealtimeMode = false;
        if (hubConnection) {
        hubConnection.stop();
        hubConnection = null;
        }
        $('#chat-history').empty();
        drawMessage({ noiDung: "Chào bạn! Cafebook có thể hỗ trợ gì cho bạn?", thoiGian: new Date() }, false, false);
        loadSessions();
        }

        async function switchSession(sessionId) {
        currentSessionId = sessionId;
        localStorage.setItem('cf_kh_session_' + idKhachHang, currentSessionId);
                
        // --- FIX 1: BẮT BUỘC RESET TRẠNG THÁI REALTIME KHI ĐỔI TAB CHAT ---
        currentIdThongBao = null;
        isRealtimeMode = false;
        if (hubConnection) {
        hubConnection.stop();
        hubConnection = null;
        }

        await loadHistory();
        loadSessions();
        }

        // Load danh sách bên trái
        async function loadSessions() {
        const res = await fetch(`${apiBaseUrl}/api/web/khachhang/hotro/sessions?guestSessionId=${initGuestSessionId}`, { headers });
        const sessions = await res.json();
        $('#sessionList').empty();
                
        let sessionFound = false;
        sessions.forEach(s => {
        if(s.sessionId === currentSessionId) sessionFound = true;
        const badge = s.idThongBao > 0 ? `<span class="htkh-badge">Nhân viên</span>` : '';
        const item = $(`<div class="htkh-session-item ${s.sessionId === currentSessionId ? 'active' : ''}" data-id="${s.sessionId}">${s.title} ${badge}</div>`);
        item.on('click', () => switchSession(s.sessionId));
        $('#sessionList').append(item);
        });

        if(!sessionFound && initGuestSessionId && currentSessionId === initGuestSessionId && sessions.length > 0) {
        switchSession(sessions[0].sessionId);
        }
        }

        $('#btnNewChat').on('click', createNewChat);

        function drawMessage(msg, isUser, isStaff = false) {
        const type = isUser ? 'user' : (isStaff ? 'staff' : 'bot');
        const icon = isUser ? 'person' : (isStaff ? 'support_agent' : 'local_cafe');
                
        let rawText = msg.noiDung || '';
        let actionButtonsHtml = '';
                
        // Nâng cấp Button UI
        const buttonRegex = /\[BUTTON:\s*(.*?)\s*\|\s*(.*?)\]/g;
        let match;
        while ((match = buttonRegex.exec(rawText)) !== null) {
        let label = match[1].trim();
        let link = match[2].trim();
        actionButtonsHtml += `<a href="${link}" class="htkh-btn-action">${label} <span class="material-symbols-outlined" style="font-size: 14px; margin-left: 4px;">arrow_forward</span></a>`;
        }

        let textContent = rawText.replace(buttonRegex, "").trim().replace(/\n/g, '<br />');
        let timeObj = msg.thoiGian ? new Date(msg.thoiGian) : new Date();
        const time = timeObj.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                
        let actionContainer = actionButtonsHtml !== '' ? `<div class="htkh-action-buttons">${actionButtonsHtml}</div>` : '';

        $('#chat-history').append(`
        <div class="htkh-row ${type}">
        <div class="htkh-avatar ${type}"><span class="material-symbols-outlined">${icon}</span></div>
        <div class="htkh-content">
        <div class="htkh-bubble">${textContent}</div>
        ${actionContainer}
        <div class="htkh-time ${isUser ? 'text-end' : 'text-start'}">${time}</div>
        </div>
        </div>
        `);
        scrollToBottom();
        }

        function showTypingIndicator() {
        $('#chat-history').append(`
        <div class="htkh-row bot" id="ai-typing-indicator">
        <div class="htkh-avatar bot"><span class="material-symbols-outlined">local_cafe</span></div>
        <div class="htkh-content">
        <div class="htkh-bubble">
        <div class="typing-indicator"><span></span><span></span><span></span></div>
        </div>
        </div>
        </div>
        `);
        scrollToBottom();
        }

        function hideTypingIndicator() {
        $('#ai-typing-indicator').remove();
        }

        function scrollToBottom() {
        const chatHistory = document.getElementById('chat-history');
        if (chatHistory) chatHistory.scrollTo({ top: chatHistory.scrollHeight, behavior: 'smooth' });
        }

        async function loadHistory() {
        const res = await fetch(`${apiBaseUrl}/api/web/khachhang/hotro/history?sessionId=${currentSessionId}`, { headers });
        const history = await res.json();
        $('#chat-history').empty();
                
        // Đảm bảo Reset lại lần nữa trước khi nạp data mới
        currentIdThongBao = null;
        isRealtimeMode = false;

        if(history.length === 0) {
        drawMessage({ noiDung: "Chào bạn!", thoiGian: new Date() }, false, false);
        } else {
        history.forEach(msg => {
        if (msg.idThongBaoHoTro > 0) currentIdThongBao = msg.idThongBaoHoTro;
        drawMessage(msg, msg.loaiTinNhan === 'KhachHang', msg.loaiTinNhan === 'NhanVien');
        });
                    
        if (currentIdThongBao) { isRealtimeMode = true; startSignalR(); }
        }
        }

        $('#chatForm').on('submit', async function(e) {
        e.preventDefault();
        const text = $('#chatMessageInput').val().trim();
        if (!text) return;

        $('#chatMessageInput').val('').prop('disabled', true);
        $('#sendBtn').prop('disabled', true);
                                
        drawMessage({ noiDung: text, thoiGian: new Date() }, true, false);

        if (isRealtimeMode && hubConnection) {
        try {
        // Phân loại lại Group Name và xử lý các biến số nguyên (int) an toàn
        const groupName = (idKhachHang && parseInt(idKhachHang) > 0) ? `khach_${idKhachHang}` : `guest_${currentSessionId}`;
        const pIdKhachHang = (idKhachHang && parseInt(idKhachHang) > 0) ? parseInt(idKhachHang) : null;
        const pIdThongBao = currentIdThongBao ? parseInt(currentIdThongBao) : null;
                
        await hubConnection.invoke(
        "SendMessageFromClient",
        groupName,
        text,
        pIdKhachHang,
        currentSessionId,
        pIdThongBao
        );
        } catch (err) {
        console.error("SignalR Send Error:", err);
        drawMessage({ noiDung: "Lỗi kết nối máy chủ. Vui lòng tải lại trang.", thoiGian: new Date() }, false, false);
        }
        } else {
        showTypingIndicator();
        try {
        const res = await fetch(`${apiBaseUrl}/api/web/khachhang/hotro/send`, {
        method: 'POST',
        headers,
        body: JSON.stringify({ noiDung: text, sessionId: currentSessionId })
        });
        const data = await res.json();
        hideTypingIndicator();
                                                
        if (data.tinNhanPhanHoi) {
        setTimeout(() => drawMessage(data.tinNhanPhanHoi, false, data.tinNhanPhanHoi.loaiTinNhan === 'NhanVien'), 100);
        }
                                                
        if (data.daChuyenNhanVien) {
        currentIdThongBao = data.idThongBaoHoTro || (data.tinNhanPhanHoi ? data.tinNhanPhanHoi.idThongBaoHoTro : null);
        isRealtimeMode = true;
        startSignalR();
        }
        loadSessions();
        } catch (error) {
        hideTypingIndicator();
        drawMessage({ noiDung: "Lỗi kết nối hệ thống. Vui lòng thử lại.", thoiGian: new Date() }, false, false);
        }
        }
                        
        $('#chatMessageInput').prop('disabled', false).focus();
        $('#sendBtn').prop('disabled', false);
        });

        async function startSignalR() {
        if (hubConnection) return;
    
        // 1. Truyền JWT Token (nếu có) để vượt qua xác thực
        const hubOptions = jwtToken ? { accessTokenFactory: () => jwtToken } : {};
        hubConnection = new signalR.HubConnectionBuilder()
        .withUrl(apiBaseUrl + "/chatHub", hubOptions)
        .build();
                        
        hubConnection.on("ReceiveMessage", msg => {
        if (msg.loaiTinNhan !== 'KhachHang') {
        drawMessage(msg, false, msg.loaiTinNhan === 'NhanVien');
        }
        });
    
        await hubConnection.start();
    
        // 2. Logic tạo tên phòng linh hoạt: Đã đăng nhập dùng khach_id, Vãng lai dùng guest_session
        const groupName = (idKhachHang && parseInt(idKhachHang) > 0) ? `khach_${idKhachHang}` : `guest_${currentSessionId}`;
        await hubConnection.invoke("JoinGroup", groupName);
        }
                    
        // Khởi tạo
        loadSessions().then(() => {
        if($('#chat-history').children().length === 0){
        loadHistory();
        }
        });
        });
    </script>
}